<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Sign Up — Voyager AI</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600&family=DM+Serif+Display:ital@0;1&display=swap" rel="stylesheet">

  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    :root {
      --green: #2C5F3F;
      --green-dark: #1e4530;
      --green-light: #EDF4EF;
      --green-border: #C2D9C9;
      --cream: #F7F5F0;
      --cream-border: #E8E6E0;
      --card-bg: #FAFAF8;
      --text-primary: #1a1a18;
      --text-muted: #666;
      --text-hint: #999;
      --white: #ffffff;
      --error: #A32D2D;
      --error-bg: #FCEBEB;
      --error-border: #F09595;
      --font-serif: 'DM Serif Display', Georgia, serif;
      --font-sans: 'DM Sans', system-ui, sans-serif;
      --radius-sm: 7px;
      --radius-md: 10px;
      --radius-lg: 14px;
    }

    body {
      font-family: var(--font-sans);
      min-height: 100vh;
      display: flex;
      background: var(--cream);
      -webkit-font-smoothing: antialiased;
    }

    /* ── Left panel ── */
    .left-panel {
      display: none;
      flex: 1;
      background: var(--green);
      flex-direction: column;
      justify-content: center;
      align-items: flex-start;
      padding: 64px 56px;
      position: relative;
      overflow: hidden;
    }

    .left-panel::before {
      content: '';
      position: absolute;
      width: 360px;
      height: 360px;
      border-radius: 50%;
      border: 1px solid rgba(255,255,255,0.08);
      top: -80px;
      right: -80px;
    }

    .left-panel::after {
      content: '';
      position: absolute;
      width: 240px;
      height: 240px;
      border-radius: 50%;
      border: 1px solid rgba(255,255,255,0.06);
      bottom: 40px;
      left: -60px;
    }

    .panel-logo {
      display: flex;
      align-items: center;
      gap: 9px;
      font-size: 18px;
      font-weight: 600;
      color: var(--white);
      margin-bottom: 64px;
      position: relative;
      z-index: 1;
    }

    .panel-logo-mark {
      width: 34px;
      height: 34px;
      background: rgba(255,255,255,0.15);
      border-radius: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 16px;
    }

    .panel-headline {
      font-family: var(--font-serif);
      font-size: clamp(30px, 3vw, 46px);
      font-weight: 400;
      color: var(--white);
      line-height: 1.1;
      letter-spacing: -0.5px;
      margin-bottom: 20px;
      position: relative;
      z-index: 1;
    }

    .panel-headline em {
      font-style: italic;
      color: rgba(255,255,255,0.7);
    }

    .panel-sub {
      font-size: 15px;
      color: rgba(255,255,255,0.6);
      line-height: 1.65;
      max-width: 340px;
      position: relative;
      z-index: 1;
      margin-bottom: 48px;
    }

    .panel-perks {
      display: flex;
      flex-direction: column;
      gap: 14px;
      position: relative;
      z-index: 1;
    }

    .panel-perk {
      display: flex;
      align-items: center;
      gap: 12px;
      font-size: 14px;
      color: rgba(255,255,255,0.8);
    }

    .perk-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: rgba(255,255,255,0.4);
      flex-shrink: 0;
    }

    /* ── Right panel ── */
    .right-panel {
      flex: 0 0 100%;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      padding: 40px 24px;
      background: var(--white);
      overflow-y: auto;
    }

    .form-wrap {
      width: 100%;
      max-width: 420px;
      animation: fadeUp 0.45s ease forwards;
    }

    /* Mobile logo */
    .mobile-logo {
      display: flex;
      align-items: center;
      gap: 9px;
      font-size: 17px;
      font-weight: 600;
      color: var(--text-primary);
      margin-bottom: 32px;
      justify-content: center;
    }

    .mobile-logo-mark {
      width: 32px;
      height: 32px;
      background: var(--green);
      border-radius: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 15px;
    }

    .form-title {
      font-family: var(--font-serif);
      font-size: 30px;
      font-weight: 400;
      color: var(--text-primary);
      margin-bottom: 6px;
      letter-spacing: -0.3px;
    }

    .form-subtitle {
      font-size: 14px;
      color: var(--text-muted);
      margin-bottom: 28px;
    }

    /* Server-side error block — markup unchanged */
    .err {
      background: var(--error-bg);
      border-left: 3px solid var(--error-border);
      border-radius: var(--radius-sm);
      padding: 12px 14px;
      margin-bottom: 20px;
      color: var(--error);
      font-size: 13px;
    }

    .err ul { margin: 0; padding-left: 16px; }

    /* Name row */
    .name-row {
      display: flex;
      gap: 12px;
    }

    .name-row .input-group { flex: 1; }

    /* Input group */
    .input-group {
      margin-bottom: 16px;
    }

    .input-group label {
      font-size: 13px;
      font-weight: 500;
      color: var(--text-primary);
      display: block;
      margin-bottom: 7px;
    }

    .input-group input {
      width: 100%;
      padding: 11px 14px;
      border: 1.5px solid var(--cream-border);
      border-radius: var(--radius-sm);
      outline: none;
      font-size: 14px;
      font-family: var(--font-sans);
      color: var(--text-primary);
      background: var(--card-bg);
      transition: border-color 0.2s, box-shadow 0.2s;
    }

    .input-group input::placeholder { color: var(--text-hint); }
    .input-group input:hover { border-color: #D0CEC8; }
    .input-group input:focus {
      border-color: var(--green);
      background: var(--white);
      box-shadow: 0 0 0 3px rgba(44,95,63,0.1);
    }

    /* Inline JS error — original IDs preserved */
    .error {
      color: var(--error);
      font-size: 12px;
      margin-top: 5px;
      display: none;
    }

    /* Password strength — original ID preserved */
    .password-strength {
      font-size: 12px;
      margin-top: 5px;
      font-weight: 500;
    }

    /* Terms checkbox */
    .options {
      font-size: 13px;
      margin-bottom: 20px;
      color: var(--text-muted);
    }

    .options label {
      display: flex;
      align-items: center;
      gap: 8px;
      cursor: pointer;
      user-select: none;
    }

    .options input[type="checkbox"] {
      width: 15px;
      height: 15px;
      accent-color: var(--green);
      cursor: pointer;
      flex-shrink: 0;
    }

    /* Submit button */
    .btn {
      width: 100%;
      padding: 12px;
      border: none;
      border-radius: var(--radius-sm);
      background: var(--green);
      color: var(--white);
      font-size: 15px;
      font-weight: 500;
      font-family: var(--font-sans);
      cursor: pointer;
      transition: background 0.2s;
      letter-spacing: -0.1px;
    }

    .btn:hover { background: var(--green-dark); }
    .btn:active { transform: scale(0.99); }

    /* Footer */
    .footer {
      text-align: center;
      margin-top: 20px;
      font-size: 14px;
      color: var(--text-muted);
    }

    .footer a {
      color: var(--green);
      text-decoration: none;
      font-weight: 500;
    }

    .footer a:hover { color: var(--green-dark); }

    /* Animation */
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(14px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    /* ── Desktop layout ── */
    @media (min-width: 768px) {
      .left-panel { display: flex; }
      .right-panel { flex: 0 0 500px; padding: 48px 52px; }
      .mobile-logo { display: none; }
    }

    @media (min-width: 1100px) {
      .right-panel { flex: 0 0 540px; }
    }

    /* ── Mobile ── */
    @media (max-width: 480px) {
      .name-row { flex-direction: column; gap: 0; }
      .right-panel { padding: 32px 20px; }
    }
  </style>
</head>
<body>

  <!-- Left decorative panel (desktop only) -->
  <div class="left-panel">
    <div class="panel-logo">
      <div class="panel-logo-mark">✈</div>
      Voyager AI
    </div>

    <h1 class="panel-headline">
      Your journey<br><em>begins here.</em>
    </h1>

    <p class="panel-sub">
      Join 2.4 million travelers who plan smarter trips with AI — in seconds, not hours.
    </p>

    <div class="panel-perks">
      <div class="panel-perk"><span class="perk-dot"></span> AI-generated day-by-day itineraries</div>
      <div class="panel-perk"><span class="perk-dot"></span> Smart budget optimizer for every trip</div>
      <div class="panel-perk"><span class="perk-dot"></span> Offline-ready plans, always accessible</div>
      <div class="panel-perk"><span class="perk-dot"></span> 180+ countries, local food & route curation</div>
    </div>
  </div>

  <!-- Right form panel -->
  <div class="right-panel">
    <div class="form-wrap">

      <!-- Mobile logo -->
      <div class="mobile-logo">
        <div class="mobile-logo-mark">✈</div>
        Voyager AI
      </div>

      <h2 class="form-title">Create your account</h2>
      <p class="form-subtitle">Start planning your next adventure for free.</p>

      <form action="/signup" method="POST" novalidate id="signupForm">

        <!-- Server-side errors (EJS) — markup unchanged -->
        <% if (errors && errors.length > 0) { %>
          <div class="err" role="alert">
            <ul>
              <% errors.forEach(error => { %>
                <li><%= error %></li>
              <% }) %>
            </ul>
          </div>
        <% } %>

        <div class="name-row">
          <div class="input-group">
            <label for="firstName">First name</label>
            <input type="text" id="firstName" name="fname" placeholder="First name" required>
          </div>
          <div class="input-group">
            <label for="lastName">Last name</label>
            <input type="text" id="lastName" name="lname" placeholder="Last name" required>
          </div>
        </div>

        <div class="input-group">
          <label for="username">Username</label>
          <input type="text" id="username" name="username" placeholder="Choose a username" required>
          <div class="error" id="usernameError">Username must be at least 3 characters.</div>
        </div>

        <div class="input-group">
          <label for="email">Email address</label>
          <input type="email" id="email" name="email" placeholder="you@example.com" required>
          <div class="error" id="emailError">Please enter a valid email address.</div>
        </div>

        <div class="input-group">
          <label for="password">Password</label>
          <input type="password" id="password" name="password" placeholder="Create a password" required>
          <div class="password-strength" id="strengthText"></div>
        </div>

        <div class="input-group">
          <label for="confirmPassword">Confirm password</label>
          <input type="password" id="confirmPassword" placeholder="Confirm your password" required>
          <div class="error" id="confirmError">Passwords do not match.</div>
        </div>

        <div class="options">
          <label><input type="checkbox" required> I agree to the Terms &amp; Conditions</label>
        </div>

        <button type="submit" class="btn">Create account</button>

      </form>

      <div class="footer">
        Already have an account? <a href="/login">Log in</a>
      </div>

    </div>
  </div>

  <!-- Original JS logic — unchanged -->
  <script>
    const form = document.getElementById('signupForm');

    const passwordInput = document.getElementById('password');
    const strengthText = document.getElementById('strengthText');

    passwordInput.addEventListener('input', () => {
      const value = passwordInput.value;

      if (value.length < 6) {
        strengthText.textContent = "Weak password";
        strengthText.style.color = "red";
      } else if (value.length < 10) {
        strengthText.textContent = "Medium strength";
        strengthText.style.color = "orange";
      } else {
        strengthText.textContent = "Strong password";
        strengthText.style.color = "green";
      }
    });

      let valid = true;

      const username = document.getElementById('username').value;
      const email = document.getElementById('email').value;
      const password = document.getElementById('password').value;
      const confirmPassword = document.getElementById('confirmPassword').value;

      if (username.length < 3) {
        document.getElementById('usernameError').style.display = 'block';
        valid = false;
      } else {
        document.getElementById('usernameError').style.display = 'none';
      }

      if (!email.includes('@')) {
        document.getElementById('emailError').style.display = 'block';
        valid = false;
      } else {
        document.getElementById('emailError').style.display = 'none';
      }

      if (password !== confirmPassword) {
        document.getElementById('confirmError').style.display = 'block';
        valid = false;
      } else {
        document.getElementById('confirmError').style.display = 'none';
      }

      // if (valid) {
      //   alert("Account Created Successfully!");
      // }
    ;
  </script>

</body>
</html>