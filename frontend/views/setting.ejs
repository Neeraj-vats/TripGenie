                </div>
                <button class="btn" onclick="showToast('Google Photos integration coming soon!')">Connect</button>
              </div>
              <div class="app-row">
                <div class="app-row-left">
                  <div class="app-icon">✉️</div>
                  <div>
                    <div class="app-name">WhatsApp</div>
                    <div class="app-desc">Share trip itineraries via WhatsApp in one tap</div>
                  </div>
                </div>
                <button class="btn" onclick="showToast('WhatsApp share integration coming soon!')">Connect</button>
              </div>
              <div class="app-row">
                <div class="app-row-left">
                  <div class="app-icon">💳</div>
                  <div>
                    <div class="app-name">UPI / payment tracker</div>
                    <div class="app-desc">Track actual trip spend vs. planned budget</div>
                  </div>
                </div>
                <button class="btn" onclick="showToast('Payment tracking coming soon!')">Connect</button>
              </div>
            </div>

            <div class="card fade-up d3">
              <div class="card-header">
                <div class="card-header-left">
                  <div class="card-header-icon">🔑</div>
                  <div>
                    <div class="card-header-title">API access</div>
                    <div class="card-header-sub">Programmatic access to your TripGenie plans</div>
                  </div>
                </div>
                <div class="plan-badge">✦ Pro only</div>
              </div>
              <div style="padding:20px 22px;">
                <p style="font-size:13px;color:var(--text-hint);line-height:1.7;margin-bottom:16px;">Upgrade to Pro to generate an API key and access your trip plans programmatically. Build custom apps, integrations, and automations on top of TripGenie.</p>
                <button class="btn btn-green" onclick="showToast('Upgrade to unlock API access!')">✦ Upgrade to Pro</button>
              </div>
            </div>

          </div>

        </div>
      </div>

    </div>
  </div>
</div>

<div class="toast" id="toast"></div>

<script>
(function () {

  /* ── Sidebar mobile ── */
  const sidebar   = document.getElementById('sidebar');
  const overlay   = document.getElementById('sidebarOverlay');
  const hamburger = document.getElementById('hamburgerBtn');
  if (hamburger) hamburger.addEventListener('click', () => { sidebar.classList.add('open'); overlay.classList.add('show'); });
  if (overlay)   overlay.addEventListener('click',   () => { sidebar.classList.remove('open'); overlay.classList.remove('show'); });

  /* ── Toast ── */
  const toastEl = document.getElementById('toast');
  window.showToast = function(msg) {
    if (!toastEl) return;
    toastEl.textContent = msg;
    toastEl.classList.add('show');
    clearTimeout(showToast._t);
    showToast._t = setTimeout(() => toastEl.classList.remove('show'), 2000);
  };

  /* ── Settings nav ── */
  const navItems = document.querySelectorAll('.settings-nav-item');
  const sections = document.querySelectorAll('.settings-section');

  navItems.forEach(item => {
    item.addEventListener('click', () => {
      navItems.forEach(n => n.classList.remove('active'));
      sections.forEach(s => s.classList.remove('visible'));
      item.classList.add('active');
      const target = document.getElementById('section-' + item.dataset.section);
      if (target) target.classList.add('visible');
    });
  });

  /* ── Pref chips toggle ── */
  document.querySelectorAll('.pref-chip').forEach(chip => {
    chip.addEventListener('click', () => chip.classList.toggle('active'));
  });

  /* ── Budget slider ── */
  const slider   = document.getElementById('budgetSlider');
  const budgetLbl= document.getElementById('budgetVal');
  if (slider && budgetLbl) {
    slider.addEventListener('input', () => {
      const v = parseInt(slider.value, 10);
      budgetLbl.textContent = '₹' + v.toLocaleString('en-IN');
    });
  }

  /* ── Live profile update ── */
  function updateProfile() {
    const fn = document.getElementById('fname')?.value || '';
    const ln = document.getElementById('lname')?.value || '';
    const em = document.getElementById('email')?.value || '';
    const full = (fn + ' ' + ln).trim();
    const initials = ((fn[0] || '') + (ln[0] || '')).toUpperCase() || 'U';
    if (document.getElementById('displayName'))  document.getElementById('displayName').textContent  = full || 'Your Name';
    if (document.getElementById('displayEmail')) document.getElementById('displayEmail').textContent = em || 'your@email.com';
    if (document.getElementById('profileAvatar')) document.getElementById('profileAvatar').childNodes[0].textContent = initials;
    if (document.getElementById('sidebarAvatar')) document.getElementById('sidebarAvatar').textContent = initials;
    if (document.getElementById('sidebarName'))   document.getElementById('sidebarName').textContent  = full || 'Your Name';
    if (document.getElementById('sidebarEmail'))  document.getElementById('sidebarEmail').textContent = em;
  }
  ['fname','lname','email'].forEach(id => {
    const el = document.getElementById(id);
    if (el) el.addEventListener('input', updateProfile);
  });

  /* ── Save ── */
  window.saveSettings = function () {
    updateProfile();
    showToast('coming soon. ✓');
  };

  window.resetForm = function () {
    ['fname','lname','email'].forEach(id => {
      const el = document.getElementById(id);
      if (el) el.value = el.defaultValue;
    });
    updateProfile();
    showToast('Changes discarded');
  };

  /* ── Danger confirm ── */
  window.confirmAction = function (action) {
    if (action === 'delete-account') {
      if (confirm('Are you sure you want to permanently delete your account? This cannot be undone.')) {
        showToast('Account deletion initiated — check your email');
      }
    } else if (action === 'clear-plans') {
      if (confirm('Delete ALL your saved trip plans? This cannot be undone.')) {
        showToast('All trip plans cleared');
      }
    }
  };

})();
</script>
</body>
</html>
