<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Dashboard — TripGenie</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600&family=DM+Serif+Display:ital@0;1&display=swap" rel="stylesheet">

  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    :root {
      --green: #2C5F3F;
      --green-dark: #1e4530;
      --green-mid: #3a7a52;
      --green-light: #EDF4EF;
      --green-border: #C2D9C9;
      --cream: #F7F5F0;
      --cream-border: #E8E6E0;
      --card-bg: #FAFAF8;
      --text-primary: #1a1a18;
      --text-muted: #666;
      --text-hint: #999;
      --white: #ffffff;
      --sidebar-bg: #1a2e22;
      --sidebar-hover: #243d2d;
      --sidebar-active: #2C5F3F;
      --sidebar-text: rgba(255,255,255,0.6);
      --sidebar-text-active: #ffffff;
      --amber: #BA7517;
      --amber-light: #FAEEDA;
      --amber-border: #FAC775;
      --font-serif: 'DM Serif Display', Georgia, serif;
      --font-sans: 'DM Sans', system-ui, sans-serif;
      --radius-sm: 7px;
      --radius-md: 10px;
      --radius-lg: 14px;
      --radius-xl: 18px;
      --sidebar-w: 240px;
      --transition: 0.2s ease;
    }

    html, body {
      height: 100%;
      font-family: var(--font-sans);
      background: var(--cream);
      color: var(--text-primary);
      -webkit-font-smoothing: antialiased;
    }

    a { text-decoration: none; color: inherit; }

    /* ─── Layout ─── */
    .dashboard { display: flex; min-height: 100vh; }

    /* ─── Sidebar ─── */
    .sidebar {
      width: var(--sidebar-w);
      background: var(--sidebar-bg);
      display: flex;
      flex-direction: column;
      padding: 28px 0;
      position: fixed;
      top: 0; left: 0;
      height: 100vh;
      z-index: 50;
      transition: transform var(--transition);
    }

    .sidebar-logo {
      display: flex;
      align-items: center;
      gap: 9px;
      padding: 0 24px;
      margin-bottom: 36px;
      font-size: 16px;
      font-weight: 600;
      color: var(--white);
    }

    .sidebar-logo-mark {
      width: 32px; height: 32px;
      background: var(--green);
      border-radius: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 15px;
      flex-shrink: 0;
    }

    .sidebar-section-label {
      font-size: 10px;
      font-weight: 600;
      letter-spacing: 1.2px;
      text-transform: uppercase;
      color: rgba(255,255,255,0.25);
      padding: 0 24px;
      margin: 20px 0 8px;
    }

    .sidebar-nav { flex: 1; display: flex; flex-direction: column; }

    .sidebar-link {
      display: flex;
      align-items: center;
      gap: 11px;
      padding: 10px 24px;
      font-size: 14px;
      font-weight: 400;
      color: var(--sidebar-text);
      transition: background var(--transition), color var(--transition);
      border-radius: 0;
      position: relative;
    }

    .sidebar-link:hover {
      background: var(--sidebar-hover);
      color: var(--white);
    }

    .sidebar-link.active {
      background: var(--sidebar-active);
      color: var(--sidebar-text-active);
      font-weight: 500;
    }

    .sidebar-link.active::before {
      content: '';
      position: absolute;
      left: 0; top: 0; bottom: 0;
      width: 3px;
      background: rgba(255,255,255,0.6);
      border-radius: 0 2px 2px 0;
    }

    .link-icon {
      font-size: 15px;
      width: 18px;
      text-align: center;
      flex-shrink: 0;
    }

    .sidebar-bottom {
      padding: 16px 24px;
      border-top: 1px solid rgba(255,255,255,0.07);
      margin-top: auto;
    }

    .sidebar-user {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 14px;
    }

    .user-avatar {
      width: 34px; height: 34px;
      border-radius: 50%;
      background: var(--green);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 13px;
      font-weight: 600;
      color: var(--white);
      flex-shrink: 0;
    }

    .user-info-name {
      font-size: 13px;
      font-weight: 500;
      color: var(--white);
    }

    .user-info-email {
      font-size: 11px;
      color: rgba(255,255,255,0.4);
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      max-width: 140px;
    }

    .logout-form button {
      background: none;
      border: none;
      color: rgba(255,255,255,0.45);
      font-size: 13px;
      font-family: var(--font-sans);
      cursor: pointer;
      padding: 0;
      display: flex;
      align-items: center;
      gap: 7px;
      transition: color var(--transition);
    }

    .logout-form button:hover { color: rgba(255,255,255,0.8); }

    /* ─── Mobile toggle ─── */
    .sidebar-overlay {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.4);
      z-index: 40;
    }

    .sidebar-overlay.show { display: block; }

    .mobile-topbar {
      display: none;
      position: sticky;
      top: 0;
      z-index: 30;
      background: var(--white);
      border-bottom: 1px solid var(--cream-border);
      padding: 14px 20px;
      align-items: center;
      justify-content: space-between;
    }

    .mobile-topbar-logo {
      display: flex;
      align-items: center;
      gap: 8px;
      font-size: 15px;
      font-weight: 600;
      color: var(--text-primary);
    }

    .mobile-topbar-logo-mark {
      width: 28px; height: 28px;
      background: var(--green);
      border-radius: 7px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 13px;
    }

    .hamburger {
      background: none;
      border: none;
      cursor: pointer;
      display: flex;
      flex-direction: column;
      gap: 4px;
      padding: 4px;
    }

    .hamburger span {
      display: block;
      width: 20px;
      height: 1.5px;
      background: var(--text-primary);
      border-radius: 2px;
    }

    /* ─── Main content ─── */
    .main {
      flex: 1;
      margin-left: var(--sidebar-w);
      min-height: 100vh;
      background: var(--cream);
    }

    /* ─── Top bar ─── */
    .topbar {
      background: var(--white);
      border-bottom: 1px solid var(--cream-border);
      padding: 18px 36px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      position: sticky;
      top: 0;
      z-index: 20;
    }

    .topbar-left h1 {
      font-family: var(--font-serif);
      font-size: 22px;
      font-weight: 400;
      color: var(--text-primary);
      letter-spacing: -0.3px;
    }

    .topbar-left p {
      font-size: 13px;
      color: var(--text-hint);
      margin-top: 2px;
    }

    .topbar-right { display: flex; align-items: center; gap: 10px; }

    /* Create Trip button — original form/action/name preserved */
    .btn {
      padding: 10px 20px;
      border-radius: var(--radius-sm);
      border: none;
      background: var(--green);
      color: var(--white);
      font-size: 14px;
      font-weight: 500;
      font-family: var(--font-sans);
      cursor: pointer;
      transition: background var(--transition);
      display: inline-flex;
      align-items: center;
      gap: 7px;
    }

    .btn:hover { background: var(--green-dark); }

    /* ─── Page content ─── */
    .content { padding: 32px 36px; }

    /* ─── Stats ─── */
    .stats-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 16px;
      margin-bottom: 32px;
    }

    .stat-card {
      background: var(--white);
      border: 1px solid var(--cream-border);
      border-radius: var(--radius-lg);
      padding: 22px 20px;
      transition: border-color var(--transition);
    }

    .stat-card:hover { border-color: var(--green-border); }

    .stat-card-top {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 14px;
    }

    .stat-icon {
      width: 38px; height: 38px;
      border-radius: 10px;
      background: var(--green-light);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 16px;
    }

    .stat-badge {
      font-size: 11px;
      font-weight: 500;
      padding: 3px 8px;
      border-radius: 99px;
      background: var(--green-light);
      color: var(--green);
      border: 1px solid var(--green-border);
    }

    .stat-badge.amber {
      background: var(--amber-light);
      color: var(--amber);
      border-color: var(--amber-border);
    }

    .stat-num {
      font-size: 28px;
      font-weight: 600;
      color: var(--text-primary);
      letter-spacing: -0.8px;
      line-height: 1.1;
      margin-bottom: 4px;
    }

    .stat-label {
      font-size: 13px;
      color: var(--text-muted);
    }

    /* ─── Two column layout ─── */
    .two-col {
      display: grid;
      grid-template-columns: 1fr 340px;
      gap: 20px;
      margin-bottom: 24px;
    }

    /* ─── Section header ─── */
    .section-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 16px;
    }

    .section-title {
      font-size: 16px;
      font-weight: 600;
      color: var(--text-primary);
    }

    .section-link {
      font-size: 13px;
      color: var(--green);
      font-weight: 500;
      transition: color var(--transition);
    }

    .section-link:hover { color: var(--green-dark); }

    /* ─── Trip cards ─── */
    .trips-panel {
      background: var(--white);
      border: 1px solid var(--cream-border);
      border-radius: var(--radius-lg);
      padding: 24px;
    }

    .trip-card {
      display: flex;
      align-items: center;
      gap: 16px;
      padding: 14px 0;
      border-bottom: 1px solid var(--cream-border);
      transition: background var(--transition);
    }

    .trip-card:last-child { border-bottom: none; padding-bottom: 0; }
    .trip-card:first-child { padding-top: 0; }

    .trip-thumb {
      width: 48px; height: 48px;
      border-radius: 10px;
      background: var(--green-light);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 20px;
      flex-shrink: 0;
    }

    .trip-info { flex: 1; min-width: 0; }

    .trip-name {
      font-size: 14px;
      font-weight: 600;
      color: var(--text-primary);
      margin-bottom: 3px;
    }

    .trip-meta {
      font-size: 12px;
      color: var(--text-hint);
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .trip-status {
      font-size: 11px;
      font-weight: 500;
      padding: 3px 10px;
      border-radius: 99px;
      flex-shrink: 0;
    }

    .status-upcoming {
      background: var(--green-light);
      color: var(--green);
      border: 1px solid var(--green-border);
    }

    .status-planned {
      background: var(--amber-light);
      color: var(--amber);
      border: 1px solid var(--amber-border);
    }

    .status-completed {
      background: #F1EFE8;
      color: #5F5E5A;
      border: 1px solid #D3D1C7;
    }

    /* ─── Quick actions ─── */
    .quick-panel {
      background: var(--white);
      border: 1px solid var(--cream-border);
      border-radius: var(--radius-lg);
      padding: 24px;
    }

    .quick-action {
      display: flex;
      align-items: center;
      gap: 13px;
      padding: 11px 0;
      border-bottom: 1px solid var(--cream-border);
      cursor: pointer;
      transition: var(--transition);
    }

    .quick-action:last-child { border-bottom: none; padding-bottom: 0; }
    .quick-action:first-child { padding-top: 0; }

    .quick-action:hover .quick-action-title { color: var(--green); }

    .quick-action-icon {
      width: 36px; height: 36px;
      border-radius: 9px;
      background: var(--green-light);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 15px;
      flex-shrink: 0;
    }

    .quick-action-title {
      font-size: 13px;
      font-weight: 600;
      color: var(--text-primary);
      margin-bottom: 2px;
      transition: color var(--transition);
    }

    .quick-action-desc {
      font-size: 12px;
      color: var(--text-hint);
    }

    .quick-arrow {
      font-size: 14px;
      color: var(--text-hint);
      margin-left: auto;
    }

    /* ─── Features row ─── */
    .features-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 16px;
    }

    .feature-card {
      background: var(--white);
      border: 1px solid var(--cream-border);
      border-radius: var(--radius-lg);
      padding: 22px;
      transition: border-color var(--transition), background var(--transition);
    }

    .feature-card:hover {
      border-color: var(--green-border);
      background: var(--green-light);
    }

    .feature-icon {
      width: 42px; height: 42px;
      border-radius: 10px;
      background: var(--green-light);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 18px;
      margin-bottom: 14px;
    }

    .feature-title {
      font-size: 14px;
      font-weight: 600;
      color: var(--text-primary);
      margin-bottom: 5px;
    }

    .feature-desc {
      font-size: 13px;
      color: var(--text-muted);
      line-height: 1.6;
    }

    /* ─── CTA banner ─── */
    .cta-banner {
      background: var(--green);
      border-radius: var(--radius-lg);
      padding: 28px 30px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 20px;
      margin-bottom: 24px;
      flex-wrap: wrap;
    }

    .cta-banner-text h3 {
      font-family: var(--font-serif);
      font-size: 20px;
      font-weight: 400;
      color: var(--white);
      margin-bottom: 5px;
      letter-spacing: -0.2px;
    }

    .cta-banner-text p {
      font-size: 13px;
      color: rgba(255,255,255,0.6);
      max-width: 420px;
    }

    .btn-white {
      background: var(--white);
      color: var(--green);
      border: none;
      padding: 10px 22px;
      border-radius: var(--radius-sm);
      font-size: 14px;
      font-weight: 600;
      font-family: var(--font-sans);
      cursor: pointer;
      transition: background var(--transition);
      white-space: nowrap;
      flex-shrink: 0;
    }

    .btn-white:hover { background: var(--green-light); }

    /* ─── Animations ─── */
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(12px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    .fade-up {
      opacity: 0;
      animation: fadeUp 0.45s ease forwards;
    }

    .d1 { animation-delay: 0.05s; }
    .d2 { animation-delay: 0.12s; }
    .d3 { animation-delay: 0.19s; }
    .d4 { animation-delay: 0.26s; }
    .d5 { animation-delay: 0.33s; }
    .d6 { animation-delay: 0.40s; }

    /* ─── Responsive ─── */
    @media (max-width: 1100px) {
      .stats-grid { grid-template-columns: repeat(2, 1fr); }
      .two-col { grid-template-columns: 1fr; }
      .features-grid { grid-template-columns: repeat(2, 1fr); }
    }

    @media (max-width: 768px) {
      .sidebar {
        transform: translateX(-100%);
      }

      .sidebar.open {
        transform: translateX(0);
      }

      .mobile-topbar { display: flex; }
      .main { margin-left: 0; }
      .topbar { display: none; }
      .content { padding: 20px 16px; }
      .stats-grid { grid-template-columns: repeat(2, 1fr); gap: 12px; }
      .features-grid { grid-template-columns: 1fr; }
      .cta-banner { flex-direction: column; align-items: flex-start; }
    }

    @media (max-width: 480px) {
      .stats-grid { grid-template-columns: 1fr 1fr; }
    }
  </style>
</head>
<body>

<!-- ─── Sidebar overlay (mobile) ─── -->
<div class="sidebar-overlay" id="sidebarOverlay"></div>

<!-- ─── Mobile top bar ─── -->
<div class="mobile-topbar">
  <div class="mobile-topbar-logo">
    <div class="mobile-topbar-logo-mark">✈</div>
    TripGenie
  </div>
  <button class="hamburger" id="hamburgerBtn">
    <span></span><span></span><span></span>
  </button>
</div>

<div
  class="dashboard"
  data-stats='<%- JSON.stringify(stats || { totalTrips: 0, totalBudget: "0", totalDays: 0, uniqueDestinations: 0 }) %>'
  data-trips='<%- JSON.stringify(recentTrips || []) %>'
>

  <!-- ─── Sidebar ─── -->
  <aside class="sidebar" id="sidebar">
    <div class="sidebar-logo">
      <div class="sidebar-logo-mark">✈</div>
      TripGenie
    </div>

    <nav class="sidebar-nav">
      <div class="sidebar-section-label">Main</div>

      <a href="#" class="sidebar-link active">
        <span class="link-icon">⊞</span> Dashboard
      </a>

      <!-- Original href preserved -->
      <a href="/myplans/<%= user._id %>" class="sidebar-link">
        <span class="link-icon">🗂</span> My Trip Plans
      </a>

      <a href="#" class="sidebar-link">
        <span class="link-icon">🗺</span> Explore Destinations
      </a>

      <div class="sidebar-section-label">Account</div>

      <a href="/settings/<%= user._id %>" class="sidebar-link">
        <span class="link-icon">⚙</span> Settings
      </a>

      <a href="#" class="sidebar-link">
        <span class="link-icon">?</span> Help & Support
      </a>
    </nav>

    <div class="sidebar-bottom">
      <div class="sidebar-user">
        <div class="user-avatar"><%=user.fname[0]%><%=user.lname[0]%></div>
        <div>
          <div class="user-info-name"><%= user.fname %>&nbsp;<%= user.lname %></div>
          <div class="user-info-email"><%= user.email %></div>
        </div>
      </div>

      <!-- Original logout form preserved -->
      <form action="/logout" method="GET" class="logout-form">
        <button type="submit">⇥ &nbsp;Log out</button>
      </form>
    </div>
  </aside>

  <!-- ─── Main content ─── -->
  <div class="main">

    <!-- Desktop topbar -->
    <div class="topbar">
      <div class="topbar-left">
        <h1>Welcome, <%= user.fname %> 👋</h1>
        <p>Here's what's happening with your travels today.</p>
      </div>
      <div class="topbar-right">
        <!-- Original form/action/name preserved -->
        <form method="POST" action="/gettripinput">
          <input type="hidden" value="<%= user._id %>" name="userid" />
          <button type="submit" class="btn">+ Create new trip</button>
        </form>
      </div>
    </div>

    <div class="content">

      <!-- ─── Stats ─── -->
      <div class="stats-grid">
        <div class="stat-card fade-up d1">
          <div class="stat-card-top">
            <div class="stat-icon">✈</div>
            <span class="stat-badge">All time</span>
          </div>
          <div class="stat-num">12</div>
          <div class="stat-label">Total trips planned</div>
        </div>

        <div class="stat-card fade-up d2">
          <div class="stat-card-top">
            <div class="stat-icon">💰</div>
            <span class="stat-badge amber">Budget</span>
          </div>
          <div class="stat-num">₹45K</div>
          <div class="stat-label">Total budget planned</div>
        </div>

        <div class="stat-card fade-up d3">
          <div class="stat-card-top">
            <div class="stat-icon">📅</div>
            <span class="stat-badge">Active</span>
          </div>
          <div class="stat-num">5</div>
          <div class="stat-label">Upcoming trips</div>
        </div>

        <div class="stat-card fade-up d4">
          <div class="stat-card-top">
            <div class="stat-icon">🌍</div>
            <span class="stat-badge">Explored</span>
          </div>
          <div class="stat-num">0</div>
          <div class="stat-label">Destinations visited</div>
        </div>
      </div>

      <!-- ─── CTA Banner ─── -->
      <div class="cta-banner fade-up d5">
        <div class="cta-banner-text">
          <h3>Ready for your next adventure?</h3>
          <p>Let TripGenie build you a complete day-by-day itinerary — with budget, routes, and local recommendations — in seconds.</p>
        </div>
        <form method="POST" action="/gettripinput">
          <input type="hidden" value="<%= user._id %>" name="userid" />
          <button type="submit" class="btn-white">Plan a new trip →</button>
        </form>
      </div>

      <!-- ─── Two column: trips + quick actions ─── -->
      <div class="two-col fade-up d6">

        <!-- Recent trips -->
        <div class="trips-panel">
          <div class="section-header">
            <span class="section-title">Your trips</span>
            <a href="/myplans/<%= user._id %>" class="section-link">View all →</a>
          </div>

          <!-- Original trip-card class preserved -->
          <div class="trip-card">
            <div class="trip-thumb">🏔</div>
            <div class="trip-info">
              <div class="trip-name">Manali Trip</div>
              <div class="trip-meta">5 Days &nbsp;·&nbsp; ₹20,000 &nbsp;·&nbsp; Adventure</div>
            </div>
            <span class="trip-status status-upcoming">Upcoming</span>
          </div>

          <div class="trip-card">
            <div class="trip-thumb">🏖</div>
            <div class="trip-info">
              <div class="trip-name">Goa Trip</div>
              <div class="trip-meta">3 Days &nbsp;·&nbsp; ₹15,000 &nbsp;·&nbsp; Leisure</div>
            </div>
            <span class="trip-status status-planned">Planned</span>
          </div>

          <div class="trip-card">
            <div class="trip-thumb">🕌</div>
            <div class="trip-info">
              <div class="trip-name">Jaipur Weekend</div>
              <div class="trip-meta">2 Days &nbsp;·&nbsp; ₹8,000 &nbsp;·&nbsp; Culture</div>
            </div>
            <span class="trip-status status-completed">Completed</span>
          </div>

          <div class="trip-card">
            <div class="trip-thumb">🌿</div>
            <div class="trip-info">
              <div class="trip-name">Coorg Retreat</div>
              <div class="trip-meta">4 Days &nbsp;·&nbsp; ₹18,000 &nbsp;·&nbsp; Nature</div>
            </div>
            <span class="trip-status status-upcoming">Upcoming</span>
          </div>

          <div class="trip-card">
            <div class="trip-thumb">🏙</div>
            <div class="trip-info">
              <div class="trip-name">Mumbai City Break</div>
              <div class="trip-meta">2 Days &nbsp;·&nbsp; ₹10,000 &nbsp;·&nbsp; Business</div>
            </div>
            <span class="trip-status status-completed">Completed</span>
          </div>
        </div>

        <!-- Quick actions -->
        <div class="quick-panel">
          <div class="section-header">
            <span class="section-title">Quick actions</span>
          </div>

          <div class="quick-action">
            <div class="quick-action-icon">🧠</div>
            <div>
              <div class="quick-action-title">Generate itinerary</div>
              <div class="quick-action-desc">AI-powered day-by-day plan</div>
            </div>
            <span class="quick-arrow">›</span>
          </div>

          <div class="quick-action">
            <div class="quick-action-icon">💰</div>
            <div>
              <div class="quick-action-title">Budget planner</div>
              <div class="quick-action-desc">Optimize your travel spend</div>
            </div>
            <span class="quick-arrow">›</span>
          </div>

          <div class="quick-action">
            <div class="quick-action-icon">🗺</div>
            <div>
              <div class="quick-action-title">Explore map</div>
              <div class="quick-action-desc">Routes and destination intel</div>
            </div>
            <span class="quick-arrow">›</span>
          </div>

          <div class="quick-action">
            <div class="quick-action-icon">🍜</div>
            <div>
              <div class="quick-action-title">Food guide</div>
              <div class="quick-action-desc">Local restaurant picks</div>
            </div>
            <span class="quick-arrow">›</span>
          </div>

          <div class="quick-action">
            <div class="quick-action-icon">📱</div>
            <div>
              <div class="quick-action-title">Download plans</div>
              <div class="quick-action-desc">Save as PDF for offline use</div>
            </div>
            <span class="quick-arrow">›</span>
          </div>
        </div>

      </div>

      <!-- ─── Features ─── -->
      <div class="features-grid">
        <div class="feature-card">
          <div class="feature-icon">🧠</div>
          <div class="feature-title">AI itinerary builder</div>
          <div class="feature-desc">Describe your trip in plain language and get a complete day-by-day plan — timings, costs, and local tips included.</div>
        </div>

        <div class="feature-card">
          <div class="feature-icon">🗺</div>
          <div class="feature-title">Smart route mapping</div>
          <div class="feature-desc">AI-optimized routes based on your interests and opening hours so you spend more time exploring.</div>
        </div>

        <div class="feature-card">
          <div class="feature-icon">💰</div>
          <div class="feature-title">Budget optimizer</div>
          <div class="feature-desc">Set your total budget and let the AI balance flights, hotels, food and activities for maximum value.</div>
        </div>
      </div>

    </div>
  </div>
</div>

<script>
  const dashboardRoot = document.querySelector('.dashboard');
  const dashboardStats = JSON.parse(
    dashboardRoot?.dataset?.stats || '{"totalTrips":0,"totalBudget":"0","totalDays":0,"uniqueDestinations":0}'
  );
  const dashboardTrips = JSON.parse(dashboardRoot?.dataset?.trips || '[]');
  const sidebar = document.getElementById('sidebar');
  const overlay = document.getElementById('sidebarOverlay');
  const hamburger = document.getElementById('hamburgerBtn');

  function openSidebar() {
    sidebar.classList.add('open');
    overlay.classList.add('show');
  }

  function closeSidebar() {
    sidebar.classList.remove('open');
    overlay.classList.remove('show');
  }

  hamburger.addEventListener('click', openSidebar);
  overlay.addEventListener('click', closeSidebar);

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        e.target.style.opacity = '1';
        e.target.style.transform = 'translateY(0)';
      }
    });
  }, { threshold: 0.08 });

  document.querySelectorAll('.feature-card, .stat-card, .trip-card, .quick-action').forEach(el => {
    el.style.transition = 'opacity 0.4s ease, transform 0.4s ease, border-color 0.2s ease, background 0.2s ease';
    observer.observe(el);
  });

  const statCards = document.querySelectorAll('.stats-grid .stat-card');
  if (statCards.length >= 4) {
    statCards[0].querySelector('.stat-num').textContent = String(dashboardStats.totalTrips ?? 0);
    statCards[1].querySelector('.stat-num').textContent = `₹${dashboardStats.totalBudget ?? '0'}`;
    statCards[2].querySelector('.stat-num').textContent = String(dashboardStats.totalDays ?? 0);
    statCards[2].querySelector('.stat-badge').textContent = 'Planned';
    statCards[2].querySelector('.stat-label').textContent = 'Total travel days planned';
    statCards[3].querySelector('.stat-num').textContent = String(dashboardStats.uniqueDestinations ?? 0);
    statCards[3].querySelector('.stat-label').textContent = 'Unique destinations saved';
  }

  const tripsPanel = document.querySelector('.trips-panel');
  const tripsHeader = tripsPanel ? tripsPanel.querySelector('.section-header') : null;
  if (tripsPanel && tripsHeader) {
    tripsPanel.querySelectorAll('.trip-card').forEach((card) => card.remove());

    const tripsToRender = dashboardTrips.length > 0
      ? dashboardTrips
      : [{
          destination: 'No trips yet',
          days: '',
          budget: '',
          type: 'Create your first AI trip plan to see it here.',
          icon: '✈',
          status: { label: 'Start', className: 'status-planned' },
        }];

    tripsToRender.forEach((trip) => {
      const card = document.createElement('div');
      card.className = 'trip-card';
      card.innerHTML = `
        <div class="trip-thumb">${trip.icon || '✈'}</div>
        <div class="trip-info">
          <div class="trip-name">${trip.destination || 'Untitled trip'}</div>
          <div class="trip-meta">${
            trip.days && trip.budget
              ? `${trip.days} Days &nbsp;·&nbsp; ₹${trip.budget} &nbsp;·&nbsp; ${trip.type || 'Trip'}`
              : (trip.type || 'Trip details unavailable')
          }</div>
        </div>
        <span class="trip-status ${trip.status?.className || 'status-planned'}">${trip.status?.label || 'Saved'}</span>
      `;
      tripsPanel.appendChild(card);
      card.style.transition = 'opacity 0.4s ease, transform 0.4s ease, border-color 0.2s ease, background 0.2s ease';
      observer.observe(card);
    });
  }
</script>

</body>
</html>
