<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Dashboard - AI Travel Planner</title>
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">

<style>
* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
  font-family: 'Poppins', sans-serif;
}

body {
  background: #0f172a;
  color: white;
}

/* Layout */
.dashboard {
  display: flex;
}

/* Sidebar */
.sidebar {
  width: 240px;
  height: 100vh;
  background: #020617;
  padding: 25px;
}

.sidebar h2 {
  margin-bottom: 40px;
}

.sidebar a {
  display: block;
  margin: 15px 0;
  color: #94a3b8;
  text-decoration: none;
  transition: 0.3s;
}

.sidebar a:hover {
  color: white;
}

/* Main */
.main {
  flex: 1;
  padding: 30px;
}

/* Header */
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.btn {
  padding: 10px 20px;
  border-radius: 25px;
  border: none;
  background: linear-gradient(135deg, #00c6ff, #0072ff);
  color: white;
  cursor: pointer;
}

/* Cards */
.cards {
  display: flex;
  gap: 20px;
  margin-top: 30px;
}

.card {
  flex: 1;
  padding: 20px;
  border-radius: 15px;
  background: #1e293b;
}

/* Trips */
.trips {
  margin-top: 30px;
}

.trip-card {
  background: #1e293b;
  padding: 15px;
  border-radius: 12px;
  margin-bottom: 15px;
}

.trip-card h4 {
  margin-bottom: 5px;
}

.trip-card p {
  font-size: 13px;
  color: #94a3b8;
}

/* Features */
.features {
  margin-top: 30px;
  display: flex;
  gap: 20px;
}

.feature {
  flex: 1;
  padding: 20px;
  background: #1e293b;
  border-radius: 12px;
}
</style>
</head>

<body>

<div class="dashboard">

  <!-- Sidebar -->
  <div class="sidebar">
    <h2>✈️ Travel AI</h2>
    <a href="#">Dashboard</a>
    <a href="/myplans/<%= user._id %>">My AI plans</a>
    <a href="#">Settings</a>
    <form action="/logout" method="GET">
      <button type="submit" style="background:none;border:none;color:#94a3b8;cursor:pointer;">
        Logout
      </button>
    </form>
  </div>

  <!-- Main Content -->
  <div class="main">

    <!-- Header -->
    <div class="header">
      <h1>Welcome, <%= user.fname %></h1>
      <form method="POST" action="/gettripinput">
        <input type="hidden" value="<%= user._id %>" name="userid" />
      <button type="submit" class="btn">
        + Create Trip
      </button>
      </form>
    </div>

    <!-- Stats Cards -->
    <div class="cards">
      <div class="card">
        <h3>12</h3>
        <p>Total Trips</p>
      </div>
      <div class="card">
        <h3>₹45,000</h3>
        <p>Total Budget Planned</p>
      </div>
      <div class="card">
        <h3>5</h3>
        <p>Upcoming Trips</p>
      </div>
    </div>

    <!-- Trips Section -->
    <div class="trips">
      <h2>Your Trips</h2>

      <div class="trip-card">
        <h4>Manali Trip</h4>
        <p>5 Days • ₹20,000 • Adventure</p>
      </div>

      <div class="trip-card">
        <h4>Goa Trip</h4>
        <p>3 Days • ₹15,000 • Leisure</p>
      </div>
    </div>

    <!-- Features Section -->
    <div class="features">
      <div class="feature">
        <h3>🧠 AI Planner</h3>
        <p>Generate smart itineraries instantly</p>
      </div>

      <div class="feature">
        <h3>🗺️ Maps</h3>
        <p>Visualize routes and locations</p>
      </div>

      <div class="feature">
        <h3>💰 Budget</h3>
        <p>Optimize your travel expenses</p>
      </div>
    </div>

  </div>

</div>

</body>
</html>