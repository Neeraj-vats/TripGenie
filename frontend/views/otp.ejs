<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>OTP Verification - AI Travel Planner</title>
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">

<style>
* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
  font-family: 'Poppins', sans-serif;
}

body {
  height: 100vh;
  background: linear-gradient(135deg, #0f2027, #203a43, #2c5364);
  display: flex;
  align-items: center;
  justify-content: center;
}

/* Card */
.container {
  width: 420px;
  padding: 40px;
  border-radius: 20px;
  background: rgba(255,255,255,0.08);
  backdrop-filter: blur(15px);
  color: white;
  text-align: center;
  box-shadow: 0 20px 40px rgba(0,0,0,0.5);
}

/* Title */
.container h2 {
  margin-bottom: 10px;
}

.container p {
  font-size: 14px;
  color: #ccc;
  margin-bottom: 25px;
}

/* OTP Input */
.input-box {
  margin-bottom: 20px;
}

.input-box input {
  width: 100%;
  padding: 14px;
  border-radius: 12px;
  border: none;
  outline: none;
  font-size: 22px;
  text-align: center;
  letter-spacing: 10px;
}

/* Button */
.btn {
  width: 100%;
  padding: 12px;
  border-radius: 25px;
  border: none;
  background: linear-gradient(135deg, #00c6ff, #0072ff);
  color: white;
  font-size: 15px;
  cursor: pointer;
  transition: 0.3s;
}

.btn:hover {
  transform: scale(1.05);
}

/* Error */
.error {
  color: #ff6b6b;
  font-size: 13px;
  display: none;
  margin-bottom: 10px;
}

/* Resend */
.resend {
  margin-top: 15px;
  font-size: 13px;
  color: #aaa;
  cursor: pointer;
}

.resend:hover {
  color: white;
}
</style>
</head>

<body>

<div class="container">

  <h2>Verify OTP</h2>
  <p>Enter the 6-digit code sent to your email</p>

  <form method="POST" action="/otp/<%=userid%>" id="otpForm">

    <div class="input-box">
      <input 
        type="text" 
        name="otp" 
        id="otp" 
        maxlength="6" 
        minlength="6"
        pattern="\d{6}" 
        placeholder="••••••" 
        required>
    </div>

    <div class="error" id="errorMsg">
      Please enter a valid 6-digit OTP
    </div>

    <button type="submit" class="btn">Verify</button>

  </form>

  <div class="resend">Resend Code</div>

</div>

<script>
const form = document.getElementById("otpForm");
const otpInput = document.getElementById("otp");
const errorMsg = document.getElementById("errorMsg");

// Allow only numbers
otpInput.addEventListener("input", () => {
  otpInput.value = otpInput.value.replace(/\D/g, "");
});

form.addEventListener("submit", function(e) {
  const otp = otpInput.value;

  if (otp.length !== 6) {
    e.preventDefault();
    errorMsg.style.display = "block";
  } else {
    errorMsg.style.display = "none";
  }
});
</script>

</body>
</html>