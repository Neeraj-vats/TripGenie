<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>AI plan — <%= trip.destination %></title>
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">
<style>
* { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Poppins', sans-serif; }
:root{
  --bg0:#050816;
  --bg1:#0b1226;
  --card: rgba(30, 41, 59, 0.66);
  --cardSolid:#1e293b;
  --border: rgba(148, 163, 184, 0.22);
  --text:#e2e8f0;
  --muted:#94a3b8;
  --accent:#38bdf8;
  --accent2:#818cf8;
  --shadow: 0 24px 60px rgba(0,0,0,.48);
}
body {
  background:
    radial-gradient(1200px 600px at 20% 5%, rgba(56,189,248,.18), transparent 55%),
    radial-gradient(900px 500px at 90% 10%, rgba(129,140,248,.14), transparent 55%),
    radial-gradient(900px 600px at 40% 110%, rgba(34,197,94,.10), transparent 50%),
    linear-gradient(180deg, var(--bg0), var(--bg1) 55%, #020617);
  color: var(--text);
  min-height: 100vh;
  padding: 32px 18px 56px;
}
.wrap { max-width: 980px; margin: 0 auto; }

@keyframes floatIn {
  from { opacity: 0; transform: translateY(10px); filter: blur(6px); }
  to { opacity: 1; transform: translateY(0); filter: blur(0); }
}

.topbar{
  display:flex;
  align-items:flex-start;
  justify-content:space-between;
  gap:16px;
  margin-bottom: 18px;
}
.brand{
  display:flex;
  flex-direction:column;
  gap:6px;
}
.brand .kicker{
  color: var(--muted);
  font-size:.86rem;
}
.brand h1{
  font-size: 1.75rem;
  letter-spacing: .2px;
  line-height: 1.15;
}
.pillRow{
  display:flex;
  flex-wrap:wrap;
  gap:10px;
  margin-top: 10px;
}
.pill{
  display:inline-flex;
  align-items:center;
  gap:8px;
  padding: 9px 12px;
  border-radius: 999px;
  border: 1px solid var(--border);
  background: rgba(2,6,23,.28);
  color: var(--muted);
  font-size: .85rem;
  transition: transform .2s ease, border-color .2s ease, background .2s ease;
}
.pill:hover{
  transform: translateY(-1px);
  border-color: rgba(56,189,248,.45);
  background: rgba(2,6,23,.42);
}
.actions{
  display:flex;
  flex-wrap:wrap;
  gap:10px;
  justify-content:flex-end;
  margin-top: 2px;
}
.btn{
  display:inline-flex;
  align-items:center;
  justify-content:center;
  gap:10px;
  padding: 10px 14px;
  border-radius: 999px;
  border: 1px solid var(--border);
  background: rgba(2,6,23,.28);
  color: var(--text);
  text-decoration:none;
  font-size: .9rem;
  transition: transform .18s ease, border-color .18s ease, background .18s ease, box-shadow .18s ease;
}
.btn:hover{
  transform: translateY(-1px);
  border-color: rgba(56,189,248,.6);
  background: rgba(2,6,23,.48);
  box-shadow: 0 12px 30px rgba(2,6,23,.35);
}
.btn.primary{
  border-color: rgba(56,189,248,.55);
  background: linear-gradient(135deg, rgba(0,198,255,.16), rgba(0,114,255,.16));
}
.btn.primary:hover{
  border-color: rgba(56,189,248,.85);
}
.btn:active{ transform: translateY(0); }

.card{
  animation: floatIn .45s ease both;
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 18px;
  box-shadow: var(--shadow);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
}
.metaCard{
  padding: 18px 20px;
}
.summary{
  color: var(--muted);
  font-size: 0.92rem;
  line-height: 1.7;
}
.summary strong{ color: var(--text); font-weight: 600; }

.contentCard{
  margin-top: 14px;
  padding: 0;
  overflow: hidden;
}
.contentHeader{
  display:flex;
  align-items:center;
  justify-content:space-between;
  gap:12px;
  padding: 14px 16px;
  border-bottom: 1px solid rgba(148,163,184,.18);
  background: rgba(2,6,23,.22);
}
.contentHeader .title{
  font-size: .92rem;
  color: var(--muted);
}
.content{
  padding: 18px 18px 22px;
  background: rgba(30,41,59,.34);
  white-space: pre-wrap;
  word-break: break-word;
  line-height: 1.75;
  font-size: 0.95rem;
}
.content code, .content pre{
  font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
}
.toast{
  position: fixed;
  left: 50%;
  bottom: 22px;
  transform: translateX(-50%);
  padding: 10px 14px;
  border-radius: 999px;
  background: rgba(2,6,23,.72);
  border: 1px solid rgba(56,189,248,.25);
  color: var(--text);
  font-size: .88rem;
  opacity: 0;
  pointer-events: none;
  transition: opacity .2s ease, transform .2s ease;
}
.toast.show{
  opacity: 1;
  transform: translateX(-50%) translateY(-2px);
}

@media (prefers-reduced-motion: reduce){
  *{ transition: none !important; animation: none !important; }
}
</style>
</head>
<body>
<div class="wrap">
  <div class="topbar">
    <div class="brand">
      <div class="kicker">AI travel plan</div>
      <h1><%= trip.destination %></h1>
      <div class="pillRow" aria-label="Trip highlights">
        <div class="pill"><strong><%= trip.days %></strong> days</div>
        <div class="pill">₹<strong><%= trip.budget %></strong></div>
        <div class="pill"><strong><%= trip.type %></strong></div>
        <div class="pill"><%= trip.transport %></div>
        <div class="pill"><%= trip.stay %></div>
      </div>
    </div>
    <div class="actions" aria-label="Actions">
      <a class="btn" href="/myplans/<%= encodeURIComponent(userid) %>">← All my plans</a>
      <a class="btn" href="/">Home</a>
      <button class="btn primary" type="button" id="copyBtn">Copy plan</button>
    </div>
  </div>

  <section class="card metaCard" aria-label="Trip preferences">
    <div class="summary">
      <div><strong>Summary</strong></div>
      <div>
        <strong><%= trip.destination %></strong> · <%= trip.days %> days · ₹<%= trip.budget %> · <%= trip.type %>
      </div>
      <div>
        Transport: <%= trip.transport %> · Stay: <%= trip.stay %>
      </div>
      <% if (trip.activities) { %><div>Activities: <%= trip.activities %></div><% } %>
      <% if (trip.extra) { %><div>Notes: <%= trip.extra %></div><% } %>
    </div>
  </section>

  <section class="card contentCard" aria-label="AI generated plan">
    <div class="contentHeader">
      <div class="title">Generated itinerary</div>
      <div style="display:flex; gap:10px; align-items:center;">
        <span style="color: var(--muted); font-size:.85rem;">Tip: scroll to read</span>
      </div>
    </div>
    <div class="content" id="planText"><%= typeof trip.final_trip_plan === 'string' ? trip.final_trip_plan : JSON.stringify(trip.final_trip_plan, null, 2) %></div>
  </section>
</div>

<div class="toast" id="toast" role="status" aria-live="polite">Copied to clipboard</div>

<script>
  (function () {
    const btn = document.getElementById('copyBtn');
    const plan = document.getElementById('planText');
    const toast = document.getElementById('toast');
    if (!btn || !plan) return;

    function showToast(text) {
      if (!toast) return;
      toast.textContent = text;
      toast.classList.add('show');
      window.clearTimeout(showToast._t);
      showToast._t = window.setTimeout(() => toast.classList.remove('show'), 1400);
    }

    btn.addEventListener('click', async () => {
      const text = plan.innerText || plan.textContent || '';
      try {
        await navigator.clipboard.writeText(text);
        showToast('Copied to clipboard');
      } catch (e) {
        showToast('Copy failed — select and copy manually');
      }
    });
  })();
</script>
</body>
</html>
