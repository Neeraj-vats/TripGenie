<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>AI plan — <%= trip.destination %></title>
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">
<style>
* { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Poppins', sans-serif; }
body {
  background: #0f172a;
  color: #e2e8f0;
  min-height: 100vh;
  padding: 32px;
}
.wrap { max-width: 880px; margin: 0 auto; }
header {
  margin-bottom: 24px;
  padding-bottom: 20px;
  border-bottom: 1px solid #334155;
}
header h1 { font-size: 1.5rem; margin-bottom: 8px; }
.summary {
  color: #94a3b8;
  font-size: 0.9rem;
  line-height: 1.6;
}
.nav { margin-top: 16px; }
.nav a {
  color: #38bdf8;
  text-decoration: none;
  margin-right: 16px;
  font-size: 0.9rem;
}
.nav a:hover { text-decoration: underline; }
.content {
  background: #1e293b;
  border-radius: 16px;
  padding: 24px 28px;
  border: 1px solid #334155;
  white-space: pre-wrap;
  word-break: break-word;
  line-height: 1.65;
  font-size: 0.95rem;
}
</style>
</head>
<body>
<div class="wrap">
  <header>
    <h1><%= trip.destination %></h1>
    <div class="summary">
      <%= trip.days %> days · ₹<%= trip.budget %> · <%= trip.type %><br>
      <%= trip.transport %> · <%= trip.stay %><br>
      <% if (trip.activities) { %>Activities: <%= trip.activities %><br><% } %>
      <% if (trip.extra) { %>Notes: <%= trip.extra %><% } %>
    </div>
    <div class="nav">
      <a href="/myplans/<%= encodeURIComponent(userid) %>">All my plans</a>
      <a href="/">Home</a>
    </div>
  </header>
  <section class="content"><%= typeof trip.final_trip_plan === 'string' ? trip.final_trip_plan : JSON.stringify(trip.final_trip_plan, null, 2) %></section>
</div>
</body>
</html>
