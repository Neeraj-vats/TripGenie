<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>AI plan — <%= trip.destination %></title>
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600&family=DM+Serif+Display:ital@0;1&display=swap" rel="stylesheet">

<style>
*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

:root {
  --green:        #2C5F3F;
  --green-dark:   #1e4530;
  --green-mid:    #3a7a52;
  --green-light:  #EDF4EF;
  --green-border: #C2D9C9;
  --cream:        #F7F5F0;
  --cream-border: #E8E6E0;
  --card-bg:      #FAFAF8;
  --white:        #ffffff;
  --text-primary: #1a1a18;
  --text-muted:   #666;
  --text-hint:    #999;
  --sidebar-bg:   #1a2e22;
  --sidebar-hover:#243d2d;
  --sidebar-active:#2C5F3F;
  --sidebar-text: rgba(255,255,255,0.6);
  --amber:        #BA7517;
  --amber-light:  #FAEEDA;
  --amber-border: #FAC775;
  --font-serif:   'DM Serif Display', Georgia, serif;
  --font-sans:    'DM Sans', system-ui, sans-serif;
  --radius-sm:    7px;
  --radius-md:    10px;
  --radius-lg:    14px;
  --radius-xl:    18px;
  --sidebar-w:    240px;
  --transition:   0.2s ease;
}

html, body {
  height: 100%;
  font-family: var(--font-sans);
  background: var(--cream);
  color: var(--text-primary);
  -webkit-font-smoothing: antialiased;
}

a { text-decoration: none; color: inherit; }

/* ─── Animations ─── */
@keyframes fadeUp {
  from { opacity: 0; transform: translateY(14px); }
  to   { opacity: 1; transform: translateY(0); }
}
@keyframes shimmer {
  0%   { background-position: -200% center; }
  100% { background-position: 200% center; }
}

.fade-up { opacity: 0; animation: fadeUp 0.45s ease forwards; }
.d1 { animation-delay: 0.05s; }
.d2 { animation-delay: 0.12s; }
.d3 { animation-delay: 0.19s; }
.d4 { animation-delay: 0.26s; }
.d5 { animation-delay: 0.33s; }
.d6 { animation-delay: 0.40s; }
.d7 { animation-delay: 0.47s; }

/* ─── Layout ─── */
.dashboard { display: flex; min-height: 100vh; }

/* ─── Sidebar ─── */
.sidebar {
  width: var(--sidebar-w);
  background: var(--sidebar-bg);
  display: flex;
  flex-direction: column;
  padding: 28px 0;
  position: fixed;
  top: 0; left: 0;
  height: 100vh;
  z-index: 50;
  transition: transform var(--transition);
}

.sidebar-logo {
  display: flex;
  align-items: center;
  gap: 9px;
  padding: 0 24px;
  margin-bottom: 36px;
  font-size: 16px;
  font-weight: 600;
  color: var(--white);
}

.sidebar-logo-mark {
  width: 32px; height: 32px;
  background: var(--green);
  border-radius: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 15px;
  flex-shrink: 0;
}

.sidebar-section-label {
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 1.2px;
  text-transform: uppercase;
  color: rgba(255,255,255,0.25);
  padding: 0 24px;
  margin: 20px 0 8px;
}

.sidebar-nav { flex: 1; display: flex; flex-direction: column; }

.sidebar-link {
  display: flex;
  align-items: center;
  gap: 11px;
  padding: 10px 24px;
  font-size: 14px;
  font-weight: 400;
  color: var(--sidebar-text);
  transition: background var(--transition), color var(--transition);
  position: relative;
}

.sidebar-link:hover { background: var(--sidebar-hover); color: var(--white); }

.sidebar-link.active {
  background: var(--sidebar-active);
  color: var(--white);
  font-weight: 500;
}

.sidebar-link.active::before {
  content: '';
  position: absolute;
  left: 0; top: 0; bottom: 0;
  width: 3px;
  background: rgba(255,255,255,0.6);
  border-radius: 0 2px 2px 0;
}

.link-icon { font-size: 15px; width: 18px; text-align: center; flex-shrink: 0; }

.sidebar-bottom {
  padding: 16px 24px;
  border-top: 1px solid rgba(255,255,255,0.07);
  margin-top: auto;
}

.sidebar-user { display: flex; align-items: center; gap: 10px; margin-bottom: 14px; }

.user-avatar {
  width: 34px; height: 34px;
  border-radius: 50%;
  background: var(--green);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 13px;
  font-weight: 600;
  color: var(--white);
  flex-shrink: 0;
}

.user-info-name { font-size: 13px; font-weight: 500; color: var(--white); }
.user-info-email { font-size: 11px; color: rgba(255,255,255,0.4); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 140px; }

/* ─── Mobile ─── */
.sidebar-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.4); z-index: 40; }
.sidebar-overlay.show { display: block; }

.mobile-topbar {
  display: none;
  position: sticky; top: 0; z-index: 30;
  background: var(--white);
  border-bottom: 1px solid var(--cream-border);
  padding: 14px 20px;
  align-items: center;
  justify-content: space-between;
}

.mobile-topbar-logo { display: flex; align-items: center; gap: 8px; font-size: 15px; font-weight: 600; color: var(--text-primary); }

.mobile-topbar-logo-mark {
  width: 28px; height: 28px;
  background: var(--green);
  border-radius: 7px;
  display: flex; align-items: center; justify-content: center;
  font-size: 13px;
}

.hamburger { background: none; border: none; cursor: pointer; display: flex; flex-direction: column; gap: 4px; padding: 4px; }
.hamburger span { display: block; width: 20px; height: 1.5px; background: var(--text-primary); border-radius: 2px; }

/* ─── Main ─── */
.main { flex: 1; margin-left: var(--sidebar-w); min-height: 100vh; background: var(--cream); }

/* ─── Topbar ─── */
.topbar {
  background: var(--white);
  border-bottom: 1px solid var(--cream-border);
  padding: 18px 36px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
  position: sticky; top: 0; z-index: 20;
}

.topbar-left h1 {
  font-family: var(--font-serif);
  font-size: 22px;
  font-weight: 400;
  color: var(--text-primary);
  letter-spacing: -0.3px;
}

.topbar-left p { font-size: 13px; color: var(--text-hint); margin-top: 2px; }
.topbar-right { display: flex; align-items: center; gap: 10px; }

.btn {
  padding: 9px 18px;
  border-radius: var(--radius-sm);
  border: 1px solid var(--cream-border);
  background: var(--white);
  color: var(--text-primary);
  font-size: 13px;
  font-weight: 500;
  font-family: var(--font-sans);
  cursor: pointer;
  transition: background var(--transition), border-color var(--transition);
  display: inline-flex;
  align-items: center;
  gap: 6px;
  white-space: nowrap;
}

.btn:hover { background: var(--cream); border-color: var(--green-border); }

.btn-primary {
  background: var(--green);
  color: var(--white);
  border-color: var(--green);
}

.btn-primary:hover { background: var(--green-dark); border-color: var(--green-dark); }

/* ─── Content ─── */
.content { padding: 32px 36px; }

/* ─── Hero card ─── */
.hero-card {
  background: var(--green);
  border-radius: var(--radius-xl);
  padding: 32px 36px;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 20px;
  margin-bottom: 24px;
  flex-wrap: wrap;
  position: relative;
  overflow: hidden;
}

.hero-card::before {
  content: '';
  position: absolute;
  top: -40px; right: -40px;
  width: 200px; height: 200px;
  background: rgba(255,255,255,0.05);
  border-radius: 50%;
}

.hero-card::after {
  content: '';
  position: absolute;
  bottom: -60px; right: 80px;
  width: 260px; height: 260px;
  background: rgba(255,255,255,0.04);
  border-radius: 50%;
}

.hero-kicker {
  font-size: 12px;
  font-weight: 500;
  letter-spacing: 1.2px;
  text-transform: uppercase;
  color: rgba(255,255,255,0.5);
  margin-bottom: 8px;
}

.hero-title {
  font-family: var(--font-serif);
  font-size: 34px;
  font-weight: 400;
  color: var(--white);
  letter-spacing: -0.5px;
  line-height: 1.1;
  margin-bottom: 16px;
}

.hero-pills { display: flex; flex-wrap: wrap; gap: 8px; }

.hero-pill {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 6px 14px;
  border-radius: 999px;
  border: 1px solid rgba(255,255,255,0.2);
  background: rgba(255,255,255,0.1);
  color: rgba(255,255,255,0.85);
  font-size: 13px;
  font-weight: 400;
  backdrop-filter: blur(4px);
}

.hero-pill strong { color: var(--white); font-weight: 600; }

.hero-actions { display: flex; gap: 10px; flex-wrap: wrap; position: relative; z-index: 1; }

.btn-white {
  background: var(--white);
  color: var(--green);
  border: none;
  padding: 9px 18px;
  border-radius: var(--radius-sm);
  font-size: 13px;
  font-weight: 600;
  font-family: var(--font-sans);
  cursor: pointer;
  transition: background var(--transition);
  display: inline-flex; align-items: center; gap: 6px;
  white-space: nowrap;
}

.btn-white:hover { background: var(--green-light); }

.btn-ghost {
  background: rgba(255,255,255,0.1);
  color: rgba(255,255,255,0.85);
  border: 1px solid rgba(255,255,255,0.2);
  padding: 9px 18px;
  border-radius: var(--radius-sm);
  font-size: 13px;
  font-weight: 500;
  font-family: var(--font-sans);
  cursor: pointer;
  transition: background var(--transition), border-color var(--transition);
  display: inline-flex; align-items: center; gap: 6px;
  white-space: nowrap;
  text-decoration: none;
}

.btn-ghost:hover { background: rgba(255,255,255,0.18); border-color: rgba(255,255,255,0.35); }

/* ─── Stats strip ─── */
.stats-strip {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12px;
  margin-bottom: 24px;
}

.stat-mini {
  background: var(--white);
  border: 1px solid var(--cream-border);
  border-radius: var(--radius-lg);
  padding: 16px 18px;
  transition: border-color var(--transition);
}

.stat-mini:hover { border-color: var(--green-border); }

.stat-mini-icon {
  font-size: 18px;
  margin-bottom: 8px;
}

.stat-mini-value {
  font-size: 20px;
  font-weight: 600;
  color: var(--text-primary);
  letter-spacing: -0.5px;
  line-height: 1.1;
  margin-bottom: 3px;
}

.stat-mini-label { font-size: 12px; color: var(--text-hint); }

/* ─── Two col ─── */
.two-col {
  display: grid;
  grid-template-columns: 1fr 300px;
  gap: 20px;
  margin-bottom: 24px;
}

/* ─── Summary card ─── */
.summary-card {
  background: var(--white);
  border: 1px solid var(--cream-border);
  border-radius: var(--radius-lg);
  overflow: hidden;
}

.card-header {
  padding: 16px 22px;
  border-bottom: 1px solid var(--cream-border);
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.card-header-title {
  font-size: 14px;
  font-weight: 600;
  color: var(--text-primary);
}

.card-header-sub {
  font-size: 12px;
  color: var(--text-hint);
}

.card-body { padding: 20px 22px; }

.pref-row {
  display: flex;
  align-items: flex-start;
  gap: 12px;
  padding: 10px 0;
  border-bottom: 1px solid var(--cream-border);
}

.pref-row:last-child { border-bottom: none; padding-bottom: 0; }
.pref-row:first-child { padding-top: 0; }

.pref-icon {
  width: 32px; height: 32px;
  border-radius: 8px;
  background: var(--green-light);
  display: flex; align-items: center; justify-content: center;
  font-size: 14px;
  flex-shrink: 0;
}

.pref-label { font-size: 12px; color: var(--text-hint); margin-bottom: 2px; }
.pref-value { font-size: 14px; font-weight: 500; color: var(--text-primary); }

/* ─── Tips panel ─── */
.tips-panel {
  background: var(--white);
  border: 1px solid var(--cream-border);
  border-radius: var(--radius-lg);
  overflow: hidden;
}

.tip-item {
  display: flex;
  gap: 12px;
  padding: 12px 18px;
  border-bottom: 1px solid var(--cream-border);
  transition: background var(--transition);
}

.tip-item:last-child { border-bottom: none; }
.tip-item:hover { background: var(--cream); }

.tip-num {
  width: 22px; height: 22px;
  border-radius: 50%;
  background: var(--green-light);
  border: 1px solid var(--green-border);
  display: flex; align-items: center; justify-content: center;
  font-size: 11px;
  font-weight: 600;
  color: var(--green);
  flex-shrink: 0;
  margin-top: 1px;
}

.tip-text { font-size: 13px; color: var(--text-muted); line-height: 1.55; }
.tip-text strong { color: var(--text-primary); font-weight: 600; }

/* ─── Itinerary section ─── */
.itinerary-card {
  background: var(--white);
  border: 1px solid var(--cream-border);
  border-radius: var(--radius-lg);
  overflow: hidden;
  margin-bottom: 24px;
}

/* ─── Day cards ─── */
#planRender {
  padding: 20px 22px;
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.day-block {
  border: 1px solid var(--cream-border);
  border-radius: var(--radius-lg);
  overflow: hidden;
  transition: border-color var(--transition), box-shadow var(--transition);
}

.day-block:hover {
  border-color: var(--green-border);
  box-shadow: 0 4px 18px rgba(44,95,63,0.08);
}

.day-block-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14px 18px;
  background: var(--cream);
  border-bottom: 1px solid var(--cream-border);
  gap: 12px;
  flex-wrap: wrap;
}

.day-label {
  display: flex;
  align-items: center;
  gap: 10px;
}

.day-badge {
  width: 30px; height: 30px;
  border-radius: 8px;
  background: var(--green);
  display: flex; align-items: center; justify-content: center;
  font-size: 12px;
  font-weight: 700;
  color: var(--white);
  flex-shrink: 0;
}

.day-title {
  font-size: 15px;
  font-weight: 600;
  color: var(--text-primary);
}

.day-places {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
}

.place-tag {
  font-size: 11px;
  padding: 4px 10px;
  border-radius: 999px;
  background: var(--green-light);
  color: var(--green);
  border: 1px solid var(--green-border);
  font-weight: 500;
}

.day-slots {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 0;
}

.day-slot {
  padding: 14px 18px;
  border-right: 1px solid var(--cream-border);
}

.day-slot:last-child { border-right: none; }

.slot-label {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.8px;
  text-transform: uppercase;
  color: var(--text-hint);
  margin-bottom: 8px;
}

.slot-dot {
  width: 6px; height: 6px;
  border-radius: 50%;
  flex-shrink: 0;
}

.slot-dot.morning  { background: #F59E0B; }
.slot-dot.afternoon{ background: var(--green-mid); }
.slot-dot.evening  { background: #7C3AED; }

.slot-text {
  font-size: 13px;
  line-height: 1.65;
  color: var(--text-muted);
}

.slot-text ul { margin-left: 16px; }

.day-fallback {
  padding: 16px 18px;
  font-size: 13px;
  line-height: 1.75;
  color: var(--text-muted);
  white-space: pre-wrap;
  word-break: break-word;
}

/* ─── Summary block (before Day 1) ─── */
.summary-intro-block {
  background: var(--green-light);
  border: 1px solid var(--green-border);
  border-radius: var(--radius-lg);
  padding: 16px 18px;
  font-size: 13px;
  line-height: 1.75;
  color: var(--text-muted);
  white-space: pre-wrap;
  word-break: break-word;
}

.plan-summary-block {
  background: linear-gradient(180deg, #fffdf8 0%, #fff 100%);
  border: 1px solid var(--amber-border);
  border-radius: var(--radius-lg);
  overflow: hidden;
}

.plan-summary-head {
  padding: 16px 18px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  background: var(--amber-light);
  border-bottom: 1px solid rgba(186,117,23,0.18);
}

.plan-summary-title {
  font-size: 15px;
  font-weight: 600;
  color: #7a4f14;
}

.plan-summary-sub {
  font-size: 12px;
  color: #9a6a22;
}

.plan-summary-body {
  padding: 18px;
  display: grid;
  gap: 12px;
}

.plan-summary-item {
  border: 1px solid var(--cream-border);
  border-radius: 12px;
  background: var(--white);
  padding: 14px 16px;
}

.plan-summary-item-title {
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 0.7px;
  text-transform: uppercase;
  color: var(--amber);
  margin-bottom: 8px;
}

.plan-summary-item-text {
  font-size: 13px;
  line-height: 1.75;
  color: var(--text-muted);
  white-space: pre-wrap;
  word-break: break-word;
}

/* ─── Raw fallback ─── */
.raw-block {
  padding: 20px 22px;
  font-size: 13px;
  line-height: 1.75;
  color: var(--text-muted);
  white-space: pre-wrap;
  word-break: break-word;
}

/* ─── Progress bar ─── */
.progress-wrap { padding: 16px 22px; border-top: 1px solid var(--cream-border); }
.progress-label { font-size: 12px; color: var(--text-hint); margin-bottom: 8px; display: flex; justify-content: space-between; }
.progress-track { height: 4px; border-radius: 99px; background: var(--cream-border); overflow: hidden; }
.progress-fill { height: 100%; background: var(--green); border-radius: 99px; transition: width 0.6s ease; }

/* ─── Footer note ─── */
.footer-note {
  background: var(--amber-light);
  border: 1px solid var(--amber-border);
  border-radius: var(--radius-lg);
  padding: 16px 20px;
  display: flex;
  gap: 12px;
  align-items: flex-start;
  margin-bottom: 24px;
}

.footer-note-icon { font-size: 18px; flex-shrink: 0; margin-top: 1px; }
.footer-note-title { font-size: 13px; font-weight: 600; color: var(--amber); margin-bottom: 3px; }
.footer-note-text  { font-size: 12px; color: #6b4a10; line-height: 1.6; }

/* ─── Hidden raw ─── */
.hiddenRaw { position: absolute; left: -9999px; top: auto; width: 1px; height: 1px; overflow: hidden; }

/* ─── Toast ─── */
.toast {
  position: fixed;
  left: 50%;
  bottom: 24px;
  transform: translateX(-50%);
  padding: 10px 20px;
  border-radius: 999px;
  background: var(--sidebar-bg);
  color: var(--white);
  font-size: 13px;
  font-weight: 500;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.2s ease, transform 0.2s ease;
  z-index: 999;
  white-space: nowrap;
}

.toast.show {
  opacity: 1;
  transform: translateX(-50%) translateY(-4px);
}

/* ─── Responsive ─── */
@media (max-width: 1100px) {
  .stats-strip { grid-template-columns: repeat(2, 1fr); }
  .two-col { grid-template-columns: 1fr; }
  .day-slots { grid-template-columns: 1fr; }
  .day-slot { border-right: none; border-bottom: 1px solid var(--cream-border); }
  .day-slot:last-child { border-bottom: none; }
}

@media (max-width: 768px) {
  .sidebar { transform: translateX(-100%); }
  .sidebar.open { transform: translateX(0); }
  .mobile-topbar { display: flex; }
  .main { margin-left: 0; }
  .topbar { display: none; }
  .content { padding: 20px 16px; }
  .stats-strip { grid-template-columns: repeat(2, 1fr); gap: 10px; }
  .hero-card { padding: 24px 22px; }
  .hero-title { font-size: 26px; }
}

@media (max-width: 480px) {
  .stats-strip { grid-template-columns: 1fr 1fr; }
}
</style>
</head>
<body>

<div class="sidebar-overlay" id="sidebarOverlay"></div>

<div class="mobile-topbar">
  <div class="mobile-topbar-logo">
    <div class="mobile-topbar-logo-mark">✈</div>
    TripGenie
  </div>
  <button class="hamburger" id="hamburgerBtn">
    <span></span><span></span><span></span>
  </button>
</div>

<div class="dashboard">

  <!-- ─── Sidebar ─── -->
  <aside class="sidebar" id="sidebar">
    <div class="sidebar-logo">
      <div class="sidebar-logo-mark">✈</div>
      TripGenie
    </div>

    <nav class="sidebar-nav">
      <div class="sidebar-section-label">Main</div>
      <a href="/back/<%=userid%>" class="sidebar-link">
        <span class="link-icon">⊞</span> Dashboard
      </a>
      <a href="/myplans/<%= encodeURIComponent(userid) %>" class="sidebar-link">
        <span class="link-icon">🗂</span> My Trip Plans
      </a>
      <a href="#" class="sidebar-link active">
        <span class="link-icon">🗺</span> Current Plan
      </a>
      <div class="sidebar-section-label">Account</div>
      <a href="/settings/<%=userid%>" class="sidebar-link">
        <span class="link-icon">⚙</span> Settings
      </a>
      <a href="#" class="sidebar-link">
        <span class="link-icon">?</span> Help & Support
      </a>
    </nav>

    <div class="sidebar-bottom">
      <div class="sidebar-user">
        <div class="user-avatar"><%= user.fname[0].toUpperCase() %><%= user.lname[0].toUpperCase() %></div>
        <div>
          <div class="user-info-name"><%= user.fname %>&nbsp;<%= user.lname %></div>
          <div class="user-info-email"><%= user.email %></div>
        </div>
      </div>
    </div>
  </aside>

  <!-- ─── Main ─── -->
  <div class="main">

    <!-- Desktop topbar -->
    <div class="topbar">
      <div class="topbar-left">
        <h1><%= trip.destination %> &nbsp;·&nbsp; AI Trip Plan</h1>
        <p>Generated itinerary — day-by-day breakdown, timings, and local tips</p>
      </div>
      <div class="topbar-right">
        <a href="/myplans/<%= encodeURIComponent(userid) %>" class="btn">← All my plans</a>
        <a href="/back/<%=userid%>" class="btn">🏠 Home</a>
        <button class="btn btn-primary" type="button" id="copyBtnTop">📋 Copy plan</button>
      </div>
    </div>

    <div class="content">

      <!-- ─── Hero ─── -->
      <div class="hero-card fade-up d1">
        <div>
          <div class="hero-kicker">AI Travel Plan</div>
          <h1 class="hero-title"><%= trip.destination %></h1>
          <div class="hero-pills">
            <div class="hero-pill"><strong><%= trip.days %></strong>&nbsp;days</div>
            <div class="hero-pill">₹<strong><%= trip.budget %></strong></div>
            <div class="hero-pill"><strong><%= trip.type %></strong></div>
            <div class="hero-pill"><%= trip.transport %></div>
            <div class="hero-pill"><%= trip.stay %></div>
          </div>
        </div>
        <div class="hero-actions">
          <a href="/myplans/<%= encodeURIComponent(userid) %>" class="btn-ghost">← All plans</a>
          <button class="btn-white" type="button" id="copyBtnHero">📋 Copy plan</button>
        </div>
      </div>

      <!-- ─── Stats strip ─── -->
      <div class="stats-strip fade-up d2">
        <div class="stat-mini">
          <div class="stat-mini-icon">📅</div>
          <div class="stat-mini-value"><%= trip.days %></div>
          <div class="stat-mini-label">Days planned</div>
        </div>
        <div class="stat-mini">
          <div class="stat-mini-icon">💰</div>
          <div class="stat-mini-value">₹<%= trip.budget %></div>
          <div class="stat-mini-label">Total budget</div>
        </div>
        <div class="stat-mini">
          <div class="stat-mini-icon">🚗</div>
          <div class="stat-mini-value" style="font-size:15px;"><%= trip.transport %></div>
          <div class="stat-mini-label">Transport</div>
        </div>
        <div class="stat-mini">
          <div class="stat-mini-icon">🏨</div>
          <div class="stat-mini-value" style="font-size:15px;"><%= trip.stay %></div>
          <div class="stat-mini-label">Stay type</div>
        </div>
      </div>

      <!-- ─── Amber note ─── -->
      <div class="footer-note fade-up d4">
        <div class="footer-note-icon">💡</div>
        <div>
          <div class="footer-note-title">AI-generated plan — review before booking</div>
          <div class="footer-note-text">This itinerary is generated by AI based on your inputs. Always verify timings, prices, and availability with official sources before making reservations. Local conditions may vary.</div>
        </div>
      </div>

      <!-- ─── Itinerary ─── -->
      <div class="itinerary-card fade-up d5">
        <div class="card-header">
          <span class="card-header-title">📋 Generated itinerary</span>
          <span class="card-header-sub">Auto-formatted · day-by-day breakdown</span>
        </div>
        <!-- Progress bar (filled by JS) -->
        <div class="progress-wrap">
          <div class="progress-label">
            <span>Plan completeness</span>
            <span id="progressLabel">—</span>
          </div>
          <div class="progress-track">
            <div class="progress-fill" id="progressFill" style="width:0%"></div>
          </div>
        </div>
        <!-- Hidden raw -->
        <textarea class="hiddenRaw" id="planRaw" readonly><%= typeof trip.final_trip_plan === 'string' ? trip.final_trip_plan : JSON.stringify(trip.final_trip_plan, null, 2) %></textarea>
        <!-- Rendered output -->
        <div id="planRender"></div>
      </div>

      <!-- ─── Two col: preferences + tips ─── -->
      <div class="two-col fade-up d3">

        <!-- Preferences -->
        <div class="summary-card">
          <div class="card-header">
            <span class="card-header-title">Trip preferences</span>
            <span class="card-header-sub">Your inputs to the AI</span>
          </div>
          <div class="card-body">
            <div class="pref-row">
              <div class="pref-icon">📍</div>
              <div>
                <div class="pref-label">Destination</div>
                <div class="pref-value"><%= trip.destination %></div>
              </div>
            </div>
            <div class="pref-row">
              <div class="pref-icon">🗓</div>
              <div>
                <div class="pref-label">Duration</div>
                <div class="pref-value"><%= trip.days %> days</div>
              </div>
            </div>
            <div class="pref-row">
              <div class="pref-icon">💸</div>
              <div>
                <div class="pref-label">Budget</div>
                <div class="pref-value">₹<%= trip.budget %></div>
              </div>
            </div>
            <div class="pref-row">
              <div class="pref-icon">🎭</div>
              <div>
                <div class="pref-label">Trip type</div>
                <div class="pref-value"><%= trip.type %></div>
              </div>
            </div>
            <div class="pref-row">
              <div class="pref-icon">🚗</div>
              <div>
                <div class="pref-label">Transport</div>
                <div class="pref-value"><%= trip.transport %></div>
              </div>
            </div>
            <div class="pref-row">
              <div class="pref-icon">🏨</div>
              <div>
                <div class="pref-label">Stay type</div>
                <div class="pref-value"><%= trip.stay %></div>
              </div>
            </div>
            <% if (trip.activities) { %>
            <div class="pref-row">
              <div class="pref-icon">🎯</div>
              <div>
                <div class="pref-label">Activities / theme</div>
                <div class="pref-value"><%= trip.activities %></div>
              </div>
            </div>
            <% } %>
            <% if (trip.extra) { %>
            <div class="pref-row">
              <div class="pref-icon">📝</div>
              <div>
                <div class="pref-label">Extra notes</div>
                <div class="pref-value"><%= trip.extra %></div>
              </div>
            </div>
            <% } %>
          </div>
        </div>

        <!-- Quick tips -->
        <div class="tips-panel">
          <div class="card-header">
            <span class="card-header-title">Travel tips</span>
            <span class="card-header-sub">For a smooth trip</span>
          </div>
          <div class="tip-item">
            <div class="tip-num">1</div>
            <div class="tip-text"><strong>Book in advance.</strong> Accommodation and transport fill up fast, especially weekends.</div>
          </div>
          <div class="tip-item">
            <div class="tip-num">2</div>
            <div class="tip-text"><strong>Carry cash.</strong> Many local vendors, autos, and smaller restaurants don't accept UPI.</div>
          </div>
          <div class="tip-item">
            <div class="tip-num">3</div>
            <div class="tip-text"><strong>Start mornings early.</strong> Popular spots are far less crowded before 9 AM.</div>
          </div>
          <div class="tip-item">
            <div class="tip-num">4</div>
            <div class="tip-text"><strong>Offline maps.</strong> Download Google Maps for your destination before you leave.</div>
          </div>
          <div class="tip-item">
            <div class="tip-num">5</div>
            <div class="tip-text"><strong>Check weather.</strong> Seasonal changes can significantly affect plans and packing.</div>
          </div>
          <div class="tip-item">
            <div class="tip-num">6</div>
            <div class="tip-text"><strong>Budget buffer.</strong> Keep 15–20% extra for unexpected spends and emergencies.</div>
          </div>
        </div>

      </div>

      <!-- ─── Bottom actions ─── -->
      <div style="display:flex; gap:12px; flex-wrap:wrap; margin-bottom:32px;" class="fade-up d6">
        <a href="/myplans/<%= encodeURIComponent(userid) %>" class="btn">← Back to all plans</a>
        <a href="/back/<%=userid%>" class="btn">🏠 Dashboard</a>
        <button class="btn btn-primary" type="button" id="copyBtnBottom">📋 Copy full plan</button>
        <button class="btn" type="button" id="printBtn" style="margin-left:auto;">🖨 Print</button>
      </div>

    </div>
  </div>
</div>

<div class="toast" id="toast" role="status" aria-live="polite">Copied to clipboard ✓</div>

<script>
(function () {
  /* ── Sidebar mobile ── */
  const sidebar  = document.getElementById('sidebar');
  const overlay  = document.getElementById('sidebarOverlay');
  const hamburger= document.getElementById('hamburgerBtn');
  if (hamburger) hamburger.addEventListener('click', () => { sidebar.classList.add('open'); overlay.classList.add('show'); });
  if (overlay)   overlay.addEventListener('click',   () => { sidebar.classList.remove('open'); overlay.classList.remove('show'); });

  /* ── Toast ── */
  const toast = document.getElementById('toast');
  function showToast(msg) {
    if (!toast) return;
    toast.textContent = msg;
    toast.classList.add('show');
    clearTimeout(showToast._t);
    showToast._t = setTimeout(() => toast.classList.remove('show'), 1600);
  }

  /* ── Print ── */
  const printBtn = document.getElementById('printBtn');
  if (printBtn) printBtn.addEventListener('click', () => window.print());

  /* ── Helpers ── */
  function el(tag, cls, children, text) {
    const n = document.createElement(tag);
    if (cls)      n.className = cls;
    if (text !== undefined) n.textContent = text;
    if (children) for (const c of children) if (c) n.appendChild(c);
    return n;
  }

  function cleanMarkdown(text) {
    if (!text) return '';
    return String(text)
      .replace(/([^\n])\s+(Day\s*\d+\b)/gi, '$1\n$2')
      .replace(/([^\n])\s+(\d+\.\s+[A-Z][^\n]*)/g, '$1\n$2')
      .replace(/^\s*#{1,6}\s+/gm, '')
      .replace(/^\s*[\*\-]\s+/gm, '• ')
      .replace(/\*\*(.+?)\*\*/g, '$1')
      .replace(/^\s*\*+\s*/gm, '')
      .replace(/```+/g, '')
      .replace(/`+/g, '')
      .trim();
  }

  function isSummaryMarker(line) {
    return /^\s*(\d+\.\s+)?(transport|stay|budget|cost|money-saving|money saving|tips|tip|notes|summary|food|flights?|accommodation|shopping|miscellaneous|total)\b/i.test(line || '');
  }

  function splitTrailingSummary(blockLines) {
    if (!blockLines || blockLines.length <= 1) {
      return { dayLines: blockLines || [], trailingSummary: [] };
    }
    const head = blockLines[0];
    const body = blockLines.slice(1);
    const summaryStart = body.findIndex((line, idx) => {
      if (!isSummaryMarker(line)) return false;
      const prev = idx > 0 ? body[idx - 1] : '';
      return !/^\s*(morning|afternoon|evening|places?)\b/i.test(prev);
    });
    if (summaryStart === -1) {
      return { dayLines: blockLines, trailingSummary: [] };
    }
    return {
      dayLines: [head].concat(body.slice(0, summaryStart).filter(Boolean)),
      trailingSummary: body.slice(summaryStart).filter(Boolean),
    };
  }

  function splitIntoDays(lines) {
    const dayIdx = [];
    lines.forEach((l, i) => { if (/^\s*day\s*\d+\b/i.test(l)) dayIdx.push(i); });
    if (!dayIdx.length) return { summary: lines, days: [], endSummary: [] };
    const summary = lines.slice(0, dayIdx[0]).filter(Boolean);
    let endSummary = [];
    const days = dayIdx.map((start, d) => {
      const end = d + 1 < dayIdx.length ? dayIdx[d + 1] : lines.length;
      const block = lines.slice(start, end).filter(Boolean);
      const split = splitTrailingSummary(block);
      if (split.trailingSummary.length) {
        endSummary = endSummary.concat(split.trailingSummary);
      }
      return split.dayLines;
    });
    return { summary, days, endSummary };
  }

  function groupSummarySections(lines) {
    const groups = [];
    let current = null;
    lines.forEach((line) => {
      const normalized = String(line || '').replace(/^(\d+\.\s+)/, '').trim();
      if (isSummaryMarker(line)) {
        if (current) groups.push(current);
        current = { title: normalized.replace(/[:\-]\s*$/, ''), lines: [] };
        return;
      }
      if (!current) current = { title: 'Trip summary', lines: [] };
      current.lines.push(line);
    });
    if (current) groups.push(current);
    return groups.filter(group => group.title || group.lines.length);
  }

  function parseSlots(blockLines) {
    const block = blockLines.join('\n');
    const out = { morning: '', afternoon: '', evening: '', places: [] };
    function grab(label, next) {
      const re = new RegExp(`(^|\\n)\\s*${label}\\s*[:\\-]?\\s*([\\s\\S]*?)(?=\\n\\s*${next}\\s*[:\\-]?\\s*|$)`, 'i');
      const m = block.match(re);
      return m ? m[2].trim() : '';
    }
    out.morning   = grab('morning',   'afternoon');
    out.afternoon = grab('afternoon', 'evening');
    out.evening   = grab('evening',   '(places|notes|budget|cost|day\\s*\\d+)');
    const pl = blockLines.find(l => /^\s*places?\s*[:\-]/i.test(l));
    if (pl) {
      out.places = pl.replace(/^\s*places?\s*[:\-]\s*/i, '').trim()
        .split(/,|\u2022|•/g).map(s => s.trim()).filter(Boolean).slice(0, 6);
    }
    return out;
  }

  /* ── Render ── */
  const rawEl = document.getElementById('planRaw');
  const mount = document.getElementById('planRender');
  if (!rawEl || !mount) return;

  const rawText = rawEl.value || '';
  const cleaned = cleanMarkdown(rawText);
  const lines   = cleaned.split(/\r?\n/).map(l => l.trim()).filter(l => l.length > 0);
  const { summary, days, endSummary } = splitIntoDays(lines);

  /* Progress bar */
  const totalDays = parseInt('<%= trip.days %>', 10) || days.length || 1;
  const filled = Math.min(100, Math.round((days.length / totalDays) * 100));
  const pFill  = document.getElementById('progressFill');
  const pLabel = document.getElementById('progressLabel');
  if (pFill)  setTimeout(() => { pFill.style.width = filled + '%'; }, 400);
  if (pLabel) pLabel.textContent = days.length + ' of ' + totalDays + ' days';

  /* Summary block */
  if (summary.length) {
    const sb = el('div', 'summary-intro-block');
    sb.textContent = summary.join('\n');
    mount.appendChild(sb);
  }

  /* Day blocks */
  if (days.length) {
    days.forEach((blockLines, idx) => {
      const head   = blockLines[0] || 'Day';
      const m      = head.match(/day\s*(\d+)/i);
      const dayNo  = m ? m[1] : String(idx + 1);
      const slots  = parseSlots(blockLines.slice(1));

      /* Place tags */
      const placesDiv = el('div', 'day-places');
      (slots.places || []).forEach(p => { placesDiv.appendChild(el('span', 'place-tag', null, p)); });

      /* Head */
      const badge   = el('div', 'day-badge', null, dayNo);
      const title   = el('div', 'day-title', null, 'Day ' + dayNo);
      const label   = el('div', 'day-label', [badge, title]);
      const dayHead = el('div', 'day-block-head', [label, slots.places.length ? placesDiv : null]);

      /* Slot builder */
      function makeSlot(labelText, text, dotClass) {
        if (!text) return null;
        const dot  = el('span', 'slot-dot ' + dotClass);
        const lbl  = el('div',  'slot-label', [dot]);
        lbl.appendChild(document.createTextNode(labelText));
        const body = el('div', 'slot-text', null, text);
        return el('div', 'day-slot', [lbl, body]);
      }

      const morningSlot   = makeSlot('Morning',   slots.morning,   'morning');
      const afternoonSlot = makeSlot('Afternoon', slots.afternoon, 'afternoon');
      const eveningSlot   = makeSlot('Evening',   slots.evening,   'evening');

      let slotArea;
      if (morningSlot || afternoonSlot || eveningSlot) {
        slotArea = el('div', 'day-slots', [morningSlot, afternoonSlot, eveningSlot]);
      } else {
        slotArea = el('div', 'day-fallback', null, blockLines.slice(1).join('\n'));
      }

      const block = el('article', 'day-block', [dayHead, slotArea]);
      mount.appendChild(block);
    });
    if (endSummary.length) {
      const wrap = el('section', 'plan-summary-block');
      const head = el('div', 'plan-summary-head', [
        el('div', null, [
          el('div', 'plan-summary-title', null, 'Plan summary'),
          el('div', 'plan-summary-sub', null, 'Transport, stay, budget, and final notes')
        ])
      ]);
      const body = el('div', 'plan-summary-body');
      groupSummarySections(endSummary).forEach((group) => {
        body.appendChild(el('div', 'plan-summary-item', [
          el('div', 'plan-summary-item-title', null, group.title || 'Summary'),
          el('div', 'plan-summary-item-text', null, group.lines.join('\n'))
        ]));
      });
      wrap.appendChild(head);
      wrap.appendChild(body);
      mount.appendChild(wrap);
    }
  } else {
    mount.appendChild(el('div', 'raw-block', null, cleaned));
  }

  /* ── Copy handlers ── */
  async function doCopy() {
    try {
      await navigator.clipboard.writeText(cleaned);
      showToast('Plan copied to clipboard ✓');
    } catch {
      showToast('Copy failed — select text manually');
    }
  }

  ['copyBtnTop','copyBtnHero','copyBtnBottom'].forEach(id => {
    const b = document.getElementById(id);
    if (b) b.addEventListener('click', doCopy);
  });

})();
</script>
</body>
</html>
