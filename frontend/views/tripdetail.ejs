<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>AI Plan – <%= trip.destination %></title>
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/marked/9.1.6/marked.min.js"></script>
<style>
* { margin: 0; padding: 0; box-sizing: border-box; }
body {
  background: linear-gradient(135deg, #0f172a 0%, #1e1b4b 100%);
  color: #e2e8f0;
  min-height: 100vh;
  font-family: 'Poppins', sans-serif;
  padding: 32px 16px;
}
.wrap { max-width: 900px; margin: 0 auto; }

/* Header */
.hero {
  background: linear-gradient(135deg, #1e293b, #312e81);
  border-radius: 20px;
  padding: 32px;
  margin-bottom: 24px;
  border: 1px solid #4338ca44;
  position: relative;
  overflow: hidden;
}
.hero::before {
  content: '✈️';
  position: absolute;
  right: 24px;
  top: 24px;
  font-size: 3rem;
  opacity: 0.3;
}
.hero h1 {
  font-size: 2rem;
  font-weight: 700;
  background: linear-gradient(90deg, #818cf8, #38bdf8);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  margin-bottom: 16px;
}
.badges {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-bottom: 16px;
}
.badge {
  background: #1e293b;
  border: 1px solid #334155;
  color: #94a3b8;
  padding: 4px 12px;
  border-radius: 20px;
  font-size: 0.8rem;
  display: flex;
  align-items: center;
  gap: 4px;
}
.nav { display: flex; gap: 12px; margin-top: 8px; }
.nav a {
  color: #38bdf8;
  text-decoration: none;
  font-size: 0.85rem;
  padding: 6px 16px;
  border: 1px solid #38bdf844;
  border-radius: 20px;
  transition: all 0.2s;
}
.nav a:hover { background: #38bdf822; }

/* Content */
.content {
  background: #1e293b;
  border-radius: 20px;
  padding: 32px;
  border: 1px solid #334155;
  line-height: 1.8;
}

/* Markdown Styles */
.content h1, .content h2, .content h3, .content h4 {
  font-weight: 600;
  margin: 28px 0 12px;
  padding-bottom: 8px;
}
.content h2 {
  font-size: 1.4rem;
  color: #818cf8;
  border-bottom: 2px solid #312e81;
}
.content h3 {
  font-size: 1.15rem;
  color: #38bdf8;
}
.content h4 {
  font-size: 1rem;
  color: #a78bfa;
}
.content p { margin-bottom: 12px; color: #cbd5e1; }
.content strong { color: #f1f5f9; font-weight: 600; }
.content em { color: #94a3b8; }
.content ul, .content ol {
  padding-left: 20px;
  margin-bottom: 12px;
}
.content li {
  color: #cbd5e1;
  margin-bottom: 6px;
  padding-left: 4px;
}
.content li::marker { color: #818cf8; }
.content hr {
  border: none;
  border-top: 1px solid #334155;
  margin: 24px 0;
}
.content blockquote {
  border-left: 3px solid #818cf8;
  padding-left: 16px;
  color: #94a3b8;
  margin: 16px 0;
}
.content code {
  background: #0f172a;
  padding: 2px 8px;
  border-radius: 4px;
  font-size: 0.9em;
  color: #38bdf8;
}

/* Day cards */
.content h4 {
  background: linear-gradient(135deg, #1e293b, #312e81);
  border: 1px solid #4338ca44;
  border-radius: 12px;
  padding: 12px 16px;
  margin-top: 20px;
}
</style>
</head>
<body>
<div class="wrap">
  <div class="hero">
    <h1>📍 <%= trip.destination %></h1>
    <div class="badges">
      <span class="badge">📅 <%= trip.days %> days</span>
      <span class="badge">💰 ₹<%= trip.budget %></span>
      <span class="badge">👥 <%= trip.type %></span>
      <span class="badge">🚗 <%= trip.transport %></span>
      <span class="badge">🏨 <%= trip.stay %></span>
      <% if (trip.activities) { %><span class="badge">🎯 <%= trip.activities %></span><% } %>
    </div>
    <div class="nav">
      <a href="/myplans/<%= encodeURIComponent(userid) %>">← All my plans</a>
      <a href="/">🏠 Home</a>
    </div>
  </div>

  <div class="content" id="planContent"></div>
</div>

<script type="application/json" id="planRaw">
<%- JSON.stringify(typeof trip.final_trip_plan === 'string' ? trip.final_trip_plan : JSON.stringify(trip.final_trip_plan, null, 2)) %>
</script>

<script>
  const rawJsonEl = document.getElementById('planRaw');
  const raw = rawJsonEl ? JSON.parse(rawJsonEl.textContent || '""') : "";
  document.getElementById('planContent').innerHTML = marked.parse(String(raw || ""));
</script>
</body>
</html>